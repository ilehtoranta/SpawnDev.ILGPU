<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>4.9.2-rc.29</Version>
		<PackageReleaseNotes>v4.9.2-rc.29: SpawnDev.ILGPU 4.9.2-rc.25 bump (Wasm spin-yield + Atomics.wait phase barrier port from Riker fork; persistent worker handlers; typed WasmBarrierDispatchMessage / WasmFlatDispatchMessage / WasmDispatchResponse records replacing anonymous-object PostMessage payloads). P2P-side: gates 25 unconditional `Console.WriteLine` calls behind a new `P2PCompute.VerboseLogging` static flag (default false) - matches the `WebTorrentClient.VerboseLogging` pattern and stops production code from building interpolated log strings on every dispatch / capability exchange / wire-close event. Per Rule 4 ("No unconditional logging in libraries"). LargeBuffer_1MB_DispatchedOverRealWebRtc_BitExact still passes 1/1 in 135s after the gating refactor.</PackageReleaseNotes>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.ILGPU.P2P</Title>
		<Authors>LostBeard</Authors>
		<Description>P2P distributed GPU compute via SpawnDev.WebTorrent. AcceleratorType.P2P — the 7th ILGPU backend. Distributes kernels across connected devices via WebRTC. Scan a QR code, contribute GPU power.</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.ILGPU</PackageProjectUrl>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.ILGPU.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>P2P;WebRTC;WebTorrent;ILGPU;GPU;DistributedCompute;GPGPU</PackageTags>
		<LangVersion>latest</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SpawnDev.ILGPU\SpawnDev.ILGPU.csproj" />
		<PackageReference Include="SpawnDev.WebTorrent" Version="3.2.2-rc.3" />
	</ItemGroup>

</Project>
