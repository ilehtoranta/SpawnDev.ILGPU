<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>4.9.2-rc.28</Version>
		<PackageReleaseNotes>v4.9.2-rc.28: Two correctness fixes + diagnostic property. (1) IR: signed `Div by pow2` no longer rewrites to `Shr` — `>>` floors toward -infinity while `/` truncates toward zero per CLR / IL / C99 / C# spec, off-by-one for every odd-negative dividend. The rewrite is now gated on `(flags &amp; ArithmeticFlags.Unsigned)`; signed Div lowers to the backend's native signed-integer-division codegen. Diagnosed by Tuvok 2026-04-28 against `Vp9ForwardDct8x8Kernel` saturation regression. Reproduced on CUDA + OpenCL via 3-test minimal repro shipped at `SpawnDev.Codecs.Demo.Shared/UnitTests/CodecsTestBase.IlgpuIntDivByTwoRepro.cs`; canonical regression now in `SpawnDev.ILGPU.Demo.Shared/UnitTests/BackendTestBase.Tests1.cs::SignedIntDivByPow2TruncateTowardZeroTest` + `SignedIntDivByPow2_LargerDivisorsTest` (verified 14/14 across all 7 backends). (2) Wasm: `[NoInlining]` void helpers no longer silently dropped — the kernel codegen's void-value skip filter ate void `MethodCall` values, so any helper invocation with `ref`/`out` parameters returned 0 from the kernel-side ref'd local because the helper was never called. Filter now excludes `MethodCall`. Companion fix in helper dispatcher: void helper functions don't push a return value, so the post-call `Drop` was a Wasm stack underflow waiting to happen — now elided. Verified 7 NoInliningVoidHelper / NoInliningOutParam / ButterflyNarrowing / NoInliningIdct16Row* tests now pass. (3) New diagnostic: `WasmAccelerator.WorkerCount` is now a public read-only property mirroring the configured worker count.</PackageReleaseNotes>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.ILGPU</Title>
		<Authors>LostBeard</Authors>
		<Description>.Net GPU compute for the browser and desktop. Write once, run on WebGPU, WebGL, Wasm, CUDA, OpenCL, and CPU.</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.ILGPU</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageIcon>icon-128.png</PackageIcon>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.ILGPU.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>Blazor;BlazorWebAssembly;Cuda;OpenCL;WebGPU;WebGL;WebAssembly;Multithreading;WebWorkers;GPGPU;ILGPU;ParallelProcessing;ComputeShader;CrossPlatform</PackageTags>
		<NoPackageAnalysis>true</NoPackageAnalysis>
		<EnableDefaultCompileItems>true</EnableDefaultCompileItems>
		<IsPackable>true</IsPackable>
		<LangVersion>latest</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.2" />
		<PackageReference Include="SpawnDev.BlazorJS" Version="3.5.3" />
	</ItemGroup>

	<!-- Conditional fork reference: in-repo dev uses ProjectReference (fast iteration); external consumers use PackageReference via NuGet -->
	<ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<ProjectReference Include="..\ILGPU\ILGPU.csproj" />
		<ProjectReference Include="..\ILGPU.Algorithms\ILGPU.Algorithms.csproj" />
	</ItemGroup>
	<ItemGroup Condition="!Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<PackageReference Include="SpawnDev.ILGPU.Fork" Version="2.0.1" />
		<PackageReference Include="SpawnDev.ILGPU.Algorithms.Fork" Version="2.0.1" />
	</ItemGroup>

	<ItemGroup>
		<None Include="Assets\icon-128.png" Pack="true" PackagePath="\" />
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
		<None Include="..\README.md" Pack="true" PackagePath="\" />
		<None Include="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<Content Remove="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<SupportedPlatform Include="browser" />
		<SupportedPlatform Include="windows" />
		<SupportedPlatform Include="linux" />
		<SupportedPlatform Include="macos" />
	</ItemGroup>

</Project>
