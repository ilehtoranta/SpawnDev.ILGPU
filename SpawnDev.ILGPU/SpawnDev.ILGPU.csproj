<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>4.9.2-rc.27</Version>
		<PackageReleaseNotes>v4.9.2-rc.27: Wasm backend stabilisation. Removes the last `memory.atomic.wait32` / `memory.atomic.notify` call from the in-kernel `EmitBarrier` path; the entire Wasm backend is now wait/notify-free. The dispatcher's phase barrier was already pure-spin (rc.25 port from Riker's fork) plus JS-side `Atomics.wait` yield for OS-level descheduling under CPU oversubscription; rc.27 brings the legacy in-kernel barrier path in line with the same strategy. Workaround for the V8 14.7+ FutexEmulation race (`g-issues.chromium.org/issues/490434403`) which makes wasm-side wait/notify unreliable across V8 / SpiderMonkey / JSC. Also changes the default `WasmBackendOptions.WorkerCount` from `navigator.hardwareConcurrency` to `Math.Max(2, navigator.hardwareConcurrency - 2)`, leaving 2 hardware threads free for the browser UI, Mono runtime, and OS - the pure-spin phase barrier needs the OS scheduler to run every worker within the spin window, and over-saturating the CPU caused workers to be descheduled long enough that other workers spin past YIELD_SPIN_THRESHOLD and yield, losing throughput. Verified: Wasm `RadixSort` 18 / 18 PASS including the 4M-element tests that timed out on rc.26 (resolved by the worker headroom). Full barrier / sort / scan suite 32 / 32 PASS. NaN / Inf / Division / BitIdentity regression suite 54 / 54 PASS (no compare-codegen regression). Override the worker count with `WasmBackendOptions.WorkerCount = N` for explicit single-tab tuning.</PackageReleaseNotes>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.ILGPU</Title>
		<Authors>LostBeard</Authors>
		<Description>.Net GPU compute for the browser and desktop. Write once, run on WebGPU, WebGL, Wasm, CUDA, OpenCL, and CPU.</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.ILGPU</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageIcon>icon-128.png</PackageIcon>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.ILGPU.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>Blazor;BlazorWebAssembly;Cuda;OpenCL;WebGPU;WebGL;WebAssembly;Multithreading;WebWorkers;GPGPU;ILGPU;ParallelProcessing;ComputeShader;CrossPlatform</PackageTags>
		<NoPackageAnalysis>true</NoPackageAnalysis>
		<EnableDefaultCompileItems>true</EnableDefaultCompileItems>
		<IsPackable>true</IsPackable>
		<LangVersion>latest</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.2" />
		<PackageReference Include="SpawnDev.BlazorJS" Version="3.5.3" />
	</ItemGroup>

	<!-- Conditional fork reference: in-repo dev uses ProjectReference (fast iteration); external consumers use PackageReference via NuGet -->
	<ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<ProjectReference Include="..\ILGPU\ILGPU.csproj" />
		<ProjectReference Include="..\ILGPU.Algorithms\ILGPU.Algorithms.csproj" />
	</ItemGroup>
	<ItemGroup Condition="!Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<PackageReference Include="SpawnDev.ILGPU.Fork" Version="2.0.1" />
		<PackageReference Include="SpawnDev.ILGPU.Algorithms.Fork" Version="2.0.1" />
	</ItemGroup>

	<ItemGroup>
		<None Include="Assets\icon-128.png" Pack="true" PackagePath="\" />
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
		<None Include="..\README.md" Pack="true" PackagePath="\" />
		<None Include="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<Content Remove="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<SupportedPlatform Include="browser" />
		<SupportedPlatform Include="windows" />
		<SupportedPlatform Include="linux" />
		<SupportedPlatform Include="macos" />
	</ItemGroup>

</Project>
