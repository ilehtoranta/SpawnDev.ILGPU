<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>4.9.2-rc.26</Version>
		<PackageReleaseNotes>v4.9.2-rc.26: IEEE 754 NaN/Inf correctness across WGSL / GLSL / Wasm / OpenCL. ILGPU IR's `CompareValue.Invert()` rewrites `clt + brfalse` as `cge + brtrue [Unordered]` and toggles the `IsUnsignedOrUnordered` flag to preserve NaN semantics. Four backends (WebGPU, WebGL, Wasm, OpenCL) ignored the flag on float compares and emitted ordered ops, so the negated branch returned FALSE for NaN where IEEE 754 says TRUE - silently corrupting any kernel doing multiple float comparisons of NaN inputs through a flag-bit construction. CUDA + CPU passed because PTX has unordered compare ops natively (setp.geu.f64) and CPU runs CIL directly. Diagnosed by Data 2026-04-29 against `WebGPUTests.AllOps_IsInf` in SpawnDev.ILGPU.ML; root cause traced via incremental multi-compare regression tests. Naga / Chrome WGSL backend has a separate long-standing bug where bit-identical NaN values compare equal (`a == b` returns TRUE and `a != b` returns FALSE on f32 NaN with matching bit patterns, both spec-violating); worked around with explicit bit-pattern NaN guards on every f32 / f16 Equal / NotEqual. Fixes: WGSL emu_f64 unordered + native f32/f16 unordered LT/LE/GT/GE + native f32/f16 Equal/NotEqual NaN guards + `var&lt;private&gt; _ilgpu_runtime_zero` seed for Inf bitcast (Naga const-eval rejects const Inf at shader creation); GLSL mirror plus `f64_from_ieee754_bits` Inf/NaN preservation for Dekker high-lane; Wasm native f32/f64 unordered NaN-OR via `f32.ne(x,x)` / `f64.ne(x,x)` + IsInf/IsNaN/IsFin source-type-vs-result-type fix; OpenCL native float unordered guard via `isunordered()` builtin. 13 new regression tests (`BackendTestBase.Tests1`): `FloatNaNComparisonTest` / `DoubleNaNComparisonTest` / `HalfNaNComparisonTest` (multi-compare flag-bit kernels exercising eq/ne/lt/gt through IR inversion - the canonical regression any future backend / codegen change must pass), `FloatInfinityArithmeticTest` / `DoubleInfinityArithmeticTest` / `HalfInfinityArithmeticTest`, `FloatDivisionByZeroTest` / `DoubleDivisionByZeroTest` / `HalfDivisionByZeroTest`, plus `DoubleNaNLessThanIsolatedTest` (regression bait that passed on all 7 backends BEFORE the multi-compare fix - smoking gun proving the bug was IR inversion, not codegen of `&lt;`), `FloatInfinityLiteralTest` / `DoubleInfinityLiteralTest` / `DoubleIsInfinityIntrinsicTest` / `DoubleIsNaNIntrinsicTest` for the original `FormatFloat` substitution bug Data flagged. Verified: 111 / 0 / 1 (skip) on the focused NaN+Inf+Division regression suite across all 7 backends.</PackageReleaseNotes>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.ILGPU</Title>
		<Authors>LostBeard</Authors>
		<Description>.Net GPU compute for the browser and desktop. Write once, run on WebGPU, WebGL, Wasm, CUDA, OpenCL, and CPU.</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.ILGPU</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageIcon>icon-128.png</PackageIcon>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.ILGPU.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>Blazor;BlazorWebAssembly;Cuda;OpenCL;WebGPU;WebGL;WebAssembly;Multithreading;WebWorkers;GPGPU;ILGPU;ParallelProcessing;ComputeShader;CrossPlatform</PackageTags>
		<NoPackageAnalysis>true</NoPackageAnalysis>
		<EnableDefaultCompileItems>true</EnableDefaultCompileItems>
		<IsPackable>true</IsPackable>
		<LangVersion>latest</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.2" />
		<PackageReference Include="SpawnDev.BlazorJS" Version="3.5.3" />
	</ItemGroup>

	<!-- Conditional fork reference: in-repo dev uses ProjectReference (fast iteration); external consumers use PackageReference via NuGet -->
	<ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<ProjectReference Include="..\ILGPU\ILGPU.csproj" />
		<ProjectReference Include="..\ILGPU.Algorithms\ILGPU.Algorithms.csproj" />
	</ItemGroup>
	<ItemGroup Condition="!Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<PackageReference Include="SpawnDev.ILGPU.Fork" Version="2.0.1" />
		<PackageReference Include="SpawnDev.ILGPU.Algorithms.Fork" Version="2.0.1" />
	</ItemGroup>

	<ItemGroup>
		<None Include="Assets\icon-128.png" Pack="true" PackagePath="\" />
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
		<None Include="..\README.md" Pack="true" PackagePath="\" />
		<None Include="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<Content Remove="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<SupportedPlatform Include="browser" />
		<SupportedPlatform Include="windows" />
		<SupportedPlatform Include="linux" />
		<SupportedPlatform Include="macos" />
	</ItemGroup>

</Project>
