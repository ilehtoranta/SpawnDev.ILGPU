<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Version>4.9.2-rc.25</Version>
		<PackageReleaseNotes>v4.9.2-rc.25: Wasm spin-yield phase barrier port from the Riker fork. Replaces pure-spin barriers with a count-and-yield pattern: after `YIELD_SPIN_THRESHOLD = 1_000_000` iterations (~5ms at ~5ns/iter), the dispatcher saves `(g, phase, savedGen)` to a per-worker yield buffer at `fenceBase+24+w*16` and returns. The JS side calls `Atomics.wait(yMem32, genIdx, savedGen, 0.05)` (50us OS-level park, NOT the broken WASM `memory.atomic.wait32` path - JS-side Atomics.wait is correct), then re-dispatches with `resumeMode=1`. The dispatcher's resume flow restores saved state and skips the tid-loop + arrival++ that already ran pre-yield. Avoids OS scheduler starvation under CPU oversub that pure-spin couldn't break, while still avoiding the engine-side WASM wait/notify race in V8 14.7+ / SpiderMonkey. Ports the persistent-handler refactor too - one OnMessage + one OnError per worker for its lifetime, with per-dispatch state via `WorkerDispatchState`. Eliminates the V8 deopt cycles that the per-dispatch attach/detach pattern accumulated over hundreds of phases (without persistent handlers, `RadixSortRepeatedResortTest` would miss its 120s test timeout even with the spin-yield fix). Adds typed `WasmBarrierDispatchMessage` / `WasmFlatDispatchMessage` / `WasmDispatchResponse` records (replaces anonymous-object PostMessage payloads per the typed-records rule). Verified: full PMT WasmTests sweep 524 passed / 7 failed / 8 skipped - the 7 failures are pre-existing codec-codegen failures (NoInlining* / ButterflyNarrowingHelper*), confirmed equally failing in the fork baseline. Investigation log: `Wasm/Notes/wait-notify-race-investigation-2026-04-26.md`.</PackageReleaseNotes>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<EmbedAllSources>true</EmbedAllSources>
		<DebugType>Embedded</DebugType>
		<Title>SpawnDev.ILGPU</Title>
		<Authors>LostBeard</Authors>
		<Description>.Net GPU compute for the browser and desktop. Write once, run on WebGPU, WebGL, Wasm, CUDA, OpenCL, and CPU.</Description>
		<PackageProjectUrl>https://github.com/LostBeard/SpawnDev.ILGPU</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageIcon>icon-128.png</PackageIcon>
		<RepositoryUrl>https://github.com/LostBeard/SpawnDev.ILGPU.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>Blazor;BlazorWebAssembly;Cuda;OpenCL;WebGPU;WebGL;WebAssembly;Multithreading;WebWorkers;GPGPU;ILGPU;ParallelProcessing;ComputeShader;CrossPlatform</PackageTags>
		<NoPackageAnalysis>true</NoPackageAnalysis>
		<EnableDefaultCompileItems>true</EnableDefaultCompileItems>
		<IsPackable>true</IsPackable>
		<LangVersion>latest</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.2" />
		<PackageReference Include="SpawnDev.BlazorJS" Version="3.5.3" />
	</ItemGroup>

	<!-- Conditional fork reference: in-repo dev uses ProjectReference (fast iteration); external consumers use PackageReference via NuGet -->
	<ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<ProjectReference Include="..\ILGPU\ILGPU.csproj" />
		<ProjectReference Include="..\ILGPU.Algorithms\ILGPU.Algorithms.csproj" />
	</ItemGroup>
	<ItemGroup Condition="!Exists('$(MSBuildThisFileDirectory)..\ILGPU\ILGPU.csproj')">
		<PackageReference Include="SpawnDev.ILGPU.Fork" Version="2.0.1" />
		<PackageReference Include="SpawnDev.ILGPU.Algorithms.Fork" Version="2.0.1" />
	</ItemGroup>

	<ItemGroup>
		<None Include="Assets\icon-128.png" Pack="true" PackagePath="\" />
		<None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
		<None Include="..\README.md" Pack="true" PackagePath="\" />
		<None Include="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<Content Remove="wwwroot\icon-128.png" />
	</ItemGroup>

	<ItemGroup>
		<SupportedPlatform Include="browser" />
		<SupportedPlatform Include="windows" />
		<SupportedPlatform Include="linux" />
		<SupportedPlatform Include="macos" />
	</ItemGroup>

</Project>
