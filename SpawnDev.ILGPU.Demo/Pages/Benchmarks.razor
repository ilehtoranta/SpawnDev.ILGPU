@page "/benchmarks"
@implements IAsyncDisposable
@using SpawnDev.ILGPU.WebGPU
@using SpawnDev.ILGPU.WebGPU.Backend
@using SpawnDev.ILGPU.WebGL
@using SpawnDev.ILGPU.WebGL.Backend
@using SpawnDev.ILGPU.Wasm
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@using SpawnDev.ILGPU.Demo.Shared.Benchmarks
@using SpawnDev.ILGPU.Demo.Shared
@using SpawnDev.ILGPU.Demo.Shared.Services
@using SpawnDev.ILGPU.P2P
@using ILGPU
@inject P2PSwarmService SwarmService
@using System.Diagnostics
@using global::ILGPU
@using global::ILGPU.Runtime


<PageTitle>Benchmarks — SpawnDev.ILGPU</PageTitle>

<div class="bench-page">
    <div class="bench-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h1 class="bench-title"><span class="gradient-text">⚡ Backend Benchmarks</span></h1>
            <SpawnDev.ILGPU.Demo.Components.P2PBadge />
        </div>
        <p class="bench-subtitle">Compare performance across WebGPU, WebGL, and Wasm backends</p>

        <div class="bench-controls">
            <button class="btn-run @(_isRunning ? "disabled" : "")" @onclick="RunAllBenchmarks" disabled="@_isRunning">
                @if (_isRunning)
                {
                    <span class="spinner"></span>
                    <span>Running…</span>
                }
                else
                {
                    <span>▶ Run All Benchmarks</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <div class="status-pill @(_hasError ? "status-error" : "status-info")">@_statusMessage</div>
        }
    </div>

    @* ── Progress ── *@
    @if (_isRunning)
    {
        <div class="progress-section">
            <div class="progress-bar-track">
                <div class="progress-bar-fill" style="width: @(_progressPercent)%"></div>
            </div>
            <div class="progress-label">@_progressLabel</div>

        </div>
    }

    @* ── Summary (at top) ── *@
    @if (_results.Count > 0 && !_isRunning)
    {
        <div class="bench-card summary-card">
            <h2>🏆 Overall Ranking</h2>
            <div class="ranking-grid">
                @{
                    var ranking = _results
                        .Where(r => r.MedianMs.HasValue)
                        .GroupBy(r => r.BackendName)
                        .Select(g => new { Name = g.Key, AvgMs = g.Average(r => r.MedianMs!.Value),
                            Wins = g.Count(r => { var bg = _results.Where(x => x.BenchmarkName == r.BenchmarkName && x.MedianMs.HasValue);
                                return bg.Any() && r.MedianMs == bg.Min(x => x.MedianMs); }) })
                        .OrderByDescending(x => x.Wins).ThenBy(x => x.AvgMs)
                        .ToList();
                    int rank = 1;
                }
                @foreach (var r in ranking)
                {
                    <div class="rank-item">
                        <span class="rank-number">#@(rank++)</span>
                        <span class="backend-dot" style="background: @GetBackendColor(r.Name)"></span>
                        <span class="rank-name">@r.Name</span>
                        <span class="rank-wins">@r.Wins 🥇</span>
                        <span class="rank-avg">avg @r.AvgMs.ToString("F1") ms</span>
                    </div>
                }
            </div>
        </div>
    }

    @* ── P2P Swarm Benchmark ── *@
    @if (SwarmService.HasSwarm)
    {
        <div class="bench-card" style="border: 1px solid #10b981;">
            <div class="bench-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h2 style="color: #10b981;">🌐 P2P Swarm Benchmark</h2>
                    <span class="bench-card-desc">Distribute compute across @SwarmService.PeerCount peers (@SwarmService.TotalTflops.ToString("N1") TFLOPS)</span>
                </div>
                <button class="btn-run @(_p2pRunning ? "disabled" : "")" @onclick="RunP2PBenchmark" disabled="@(_p2pRunning || !SwarmService.IsActive)" style="background: #10b981;">
                    @if (_p2pRunning)
                    {
                        <span class="spinner"></span>
                        <span>Running…</span>
                    }
                    else if (!SwarmService.IsActive)
                    {
                        <span>⏳ Waiting for peers</span>
                    }
                    else
                    {
                        <span>▶ Run P2P Benchmark</span>
                    }
                </button>
            </div>

            @if (_p2pResults.Count > 0)
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 10px; margin-top: 12px;">
                    @foreach (var pr in _p2pResults)
                    {
                        <div style="background: var(--card-bg, #1e293b); border-radius: 6px; padding: 12px; border-left: 3px solid @(pr.Success ? "#10b981" : "#ef4444");">
                            <div style="font-size: 13px; font-weight: bold; color: var(--text-primary, #f1f5f9);">@pr.Label</div>
                            <div style="font-family: monospace; font-size: 10px; color: var(--text-muted, #64748b); margin: 2px 0;">Peer: @(pr.PeerId ?? "local")</div>
                            @if (pr.Success)
                            {
                                <div style="font-size: 18px; font-weight: bold; color: #10b981;">@pr.DurationMs.ToString("F1") ms</div>
                                <div style="font-size: 11px; color: var(--text-muted, #64748b);">@pr.Elements.ToString("N0") elements</div>
                            }
                            else
                            {
                                <div style="font-size: 12px; color: #ef4444;">@pr.Error</div>
                            }
                        </div>
                    }
                </div>

                @if (_p2pAggregateMs > 0)
                {
                    <div style="margin-top: 12px; padding: 12px; background: var(--card-bg, #0f172a); border-radius: 6px; display: flex; gap: 24px; flex-wrap: wrap;">
                        <div>
                            <div style="font-size: 24px; font-weight: bold; color: #10b981;">@_p2pAggregateMs.ToString("F1") ms</div>
                            <div style="font-size: 11px; color: var(--text-muted, #64748b);">Total Wall Time</div>
                        </div>
                        <div>
                            <div style="font-size: 24px; font-weight: bold; color: #3b82f6;">@_p2pTotalElements.ToString("N0")</div>
                            <div style="font-size: 11px; color: var(--text-muted, #64748b);">Total Elements</div>
                        </div>
                        <div>
                            <div style="font-size: 24px; font-weight: bold; color: #a78bfa;">@BenchmarkRunner.FormatThroughput(_p2pTotalElements / (_p2pAggregateMs / 1000.0), "elem")</div>
                            <div style="font-size: 11px; color: var(--text-muted, #64748b);">Aggregate Throughput</div>
                        </div>
                        <div>
                            <div style="font-size: 24px; font-weight: bold; color: #f59e0b;">@_p2pResults.Count(r => r.Success)/@_p2pResults.Count</div>
                            <div style="font-size: 11px; color: var(--text-muted, #64748b);">Chunks Succeeded</div>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @* ── Results ── *@
    @foreach (var bench in BenchmarkDefs.All)
    {
        var benchResults = _results.Where(r => r.BenchmarkName == bench.Id).ToList();
        if (benchResults.Count == 0) continue;

        <div class="bench-card">
            <div class="bench-card-header">
                <h2>@bench.Icon @bench.Name</h2>
                <span class="bench-card-desc">@bench.Description</span>
            </div>

            @* Table *@
            <div class="bench-table-wrap">
                <table class="bench-table">
                    <thead>
                        <tr>
                            <th>Backend</th>
                            <th>Warmup (ms)</th>
                            <th>Median (ms)</th>
                            <th>Throughput</th>
                            <th>Elements</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in benchResults.OrderBy(r => r.MedianMs ?? double.MaxValue))
                        {
                            var isBest = r.MedianMs.HasValue && r.MedianMs == benchResults.Where(x => x.MedianMs.HasValue).Min(x => x.MedianMs);
                            <tr class="@(isBest ? "row-best" : "") @(r.Failed ? "row-failed" : "")">
                                <td>
                                    <span class="backend-dot" style="background: @GetBackendColor(r.BackendName)"></span>
                                    @r.BackendName
                                </td>
                                <td>@(r.WarmupMs > 0 ? r.WarmupMs.ToString("F0") : "—")</td>
                                <td>@(r.MedianMs.HasValue ? r.MedianMs.Value.ToString("F2") : "—")</td>
                                <td>@(r.Throughput ?? "—")</td>
                                <td>@(r.ElementCount > 0 ? r.ElementCount.ToString("N0") : "—")</td>
                                <td>
                                    @if (r.Failed)
                                    {
                                        <span class="status-badge badge-fail" title="@r.Error">✗ @TruncateError(r.Error)</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge badge-ok">✓</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Canvas chart *@
            <canvas id="chart-@bench.Id" class="bench-chart" width="700" height="260"></canvas>
        </div>
    }
</div>

@* ========================== STYLES ========================== *@
<style>
    /* ── Page ── */
    .bench-page { max-width: 960px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }
    .bench-header { text-align: center; margin-bottom: 2rem; }
    .bench-title { font-size: 2rem; margin: 0; }
    .gradient-text { background: linear-gradient(135deg, #3b82f6, #a855f7, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .bench-subtitle { color: #94a3b8; margin-top: 0.4rem; font-size: 1rem; }

    /* ── Controls ── */
    .bench-controls { display: flex; align-items: center; gap: 1rem; justify-content: center; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .btn-run {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.7rem 2rem; border: none; border-radius: 8px;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: #fff;
        font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.2s;
    }
    .btn-run:hover:not(.disabled) { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(139,92,246,0.35); }
    .btn-run.disabled { opacity: 0.6; cursor: not-allowed; }
    .spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.6s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .status-pill { padding: 0.35rem 1rem; border-radius: 999px; font-size: 0.85rem; font-weight: 500; }
    .status-info { background: rgba(59,130,246,0.15); color: #93c5fd; }
    .status-error { background: rgba(239,68,68,0.15); color: #fca5a5; }

    /* ── Progress ── */
    .progress-section { margin-bottom: 1.5rem; }
    .progress-bar-track { height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #3b82f6, #a855f7); transition: width 0.3s ease; border-radius: 3px; }
    .progress-label { font-size: 0.8rem; color: #94a3b8; margin-top: 0.3rem; text-align: center; }
    .freeze-warning {
        display: flex; align-items: center; gap: 0.5rem; justify-content: center;
        margin-top: 0.6rem; padding: 0.5rem 1rem; border-radius: 8px;
        background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3);
        color: #fbbf24; font-size: 0.82rem;
    }
    .freeze-icon { font-size: 1rem; }

    /* ── Cards ── */
    .bench-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;
        transition: border-color 0.2s;
    }
    .bench-card:hover { border-color: rgba(139,92,246,0.25); }
    .bench-card-header { margin-bottom: 1rem; }
    .bench-card-header h2 { font-size: 1.2rem; margin: 0 0 0.2rem; }
    .bench-card-desc { font-size: 0.85rem; color: #94a3b8; }

    /* ── Table ── */
    .bench-table-wrap { overflow-x: auto; margin-bottom: 1rem; }
    .bench-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    .bench-table th { text-align: left; padding: 0.5rem 0.7rem; color: #94a3b8; font-weight: 600; border-bottom: 1px solid rgba(255,255,255,0.08); white-space: nowrap; }
    .bench-table td { padding: 0.5rem 0.7rem; border-bottom: 1px solid rgba(255,255,255,0.04); white-space: nowrap; }
    .row-best td { background: rgba(34,197,94,0.06); }
    .row-failed td { opacity: 0.6; }
    .backend-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 0.4rem; vertical-align: middle; }
    .status-badge { font-size: 0.78rem; padding: 2px 8px; border-radius: 4px; }
    .badge-ok { background: rgba(34,197,94,0.12); color: #4ade80; }
    .badge-fail { background: rgba(239,68,68,0.12); color: #fca5a5; }

    /* ── Chart ── */
    .bench-chart { width: 100%; max-width: 700px; height: 260px; display: block; margin: 0 auto; }

    /* ── Summary ── */
    .summary-card h2 { font-size: 1.3rem; margin: 0 0 1rem; }
    .ranking-grid { display: flex; flex-direction: column; gap: 0.6rem; }
    .rank-item { display: flex; align-items: center; gap: 0.7rem; padding: 0.5rem 0.8rem; background: rgba(255,255,255,0.03); border-radius: 8px; }
    .rank-number { font-weight: 700; color: #a855f7; min-width: 2rem; }
    .rank-name { font-weight: 600; flex: 1; }
    .rank-wins { color: #facc15; font-weight: 600; }
    .rank-avg { color: #94a3b8; font-size: 0.85rem; }
</style>

@* ========================== CODE ========================== *@
@code {
    // ── State ──
    private bool _isRunning;
    private bool _hasError;
    private string _statusMessage = "";
    private string _progressLabel = "";
    private int _progressPercent;
    private string _currentBackend = "";
    private readonly List<BenchmarkResult> _results = new();

    // ── P2P Benchmark State ──
    private bool _p2pRunning;
    private readonly List<P2PBenchmarkChunk> _p2pResults = new();
    private double _p2pAggregateMs;
    private long _p2pTotalElements;

    private record P2PBenchmarkChunk
    {
        public string Label { get; init; } = "";
        public string? PeerId { get; init; }
        public bool Success { get; init; }
        public double DurationMs { get; init; }
        public long Elements { get; init; }
        public string? Error { get; init; }
    }

    private async Task RunP2PBenchmark()
    {
        if (!SwarmService.IsActive || _p2pRunning) return;
        var compute = SwarmService.Compute;
        if (compute == null) return;

        _p2pRunning = true;
        _p2pResults.Clear();
        _p2pAggregateMs = 0;
        _p2pTotalElements = 0;
        StateHasChanged();

        var sw = Stopwatch.StartNew();
        int peerCount = compute.PeerCount;
        int totalElements = 1_000_000;

        // Split proportionally by TFLOPS
        var peers = compute.Coordinator.GetPeerList().Where(p => p.IsConnected).ToList();
        double totalTflops = peers.Sum(p => p.Capabilities?.EstimatedTflops ?? 0.1);

        var chunks = new List<(string peerId, int elements)>();
        int assigned = 0;
        for (int i = 0; i < peers.Count; i++)
        {
            double peerTflops = peers[i].Capabilities?.EstimatedTflops ?? 0.1;
            int chunkElements = (i == peers.Count - 1)
                ? totalElements - assigned
                : (int)(totalElements * (peerTflops / totalTflops));
            chunks.Add((peers[i].PeerId, chunkElements));
            assigned += chunkElements;

            _p2pResults.Add(new P2PBenchmarkChunk
            {
                Label = $"Chunk {i} ({chunkElements:N0} elem)",
                PeerId = peers[i].PeerId[..Math.Min(10, peers[i].PeerId.Length)],
                Elements = chunkElements,
            });
        }
        StateHasChanged();

        // Dispatch all chunks
        var tasks = new List<Task>();
        for (int i = 0; i < chunks.Count; i++)
        {
            var idx = i;
            var (peerId, elements) = chunks[idx];
            tasks.Add(Task.Run(async () =>
            {
                var chunkSw = Stopwatch.StartNew();
                try
                {
                    // Generate data
                    var data = new byte[elements * 4];
                    for (int j = 0; j < Math.Min(elements, 1000); j++)
                        BitConverter.TryWriteBytes(data.AsSpan(j * 4), (float)j);

                    compute.DispatchToSwarm(
                        typeof(P2PDemoKernels), nameof(P2PDemoKernels.MultiplyBy2),
                        elements,
                        ($"bench_{idx}", data, 4));

                    // Wait for dispatch acknowledgment
                    await Task.Delay(100);
                    chunkSw.Stop();

                    _p2pResults[idx] = _p2pResults[idx] with
                    {
                        Success = true,
                        DurationMs = chunkSw.Elapsed.TotalMilliseconds,
                    };
                }
                catch (Exception ex)
                {
                    chunkSw.Stop();
                    _p2pResults[idx] = _p2pResults[idx] with
                    {
                        Success = false,
                        DurationMs = chunkSw.Elapsed.TotalMilliseconds,
                        Error = ex.Message,
                    };
                }
                await InvokeAsync(StateHasChanged);
            }));
        }

        await Task.WhenAll(tasks);
        sw.Stop();

        _p2pAggregateMs = sw.Elapsed.TotalMilliseconds;
        _p2pTotalElements = chunks.Sum(c => (long)c.elements);
        _p2pRunning = false;
        StateHasChanged();
    }

    // ── Backend colors ──
    private static string GetBackendColor(string name) => name switch
    {
        "WebGPU" => "#22c55e",
        "Wasm" => "#a855f7",
        "WebGL" => "#f97316",
        _ => "#94a3b8"
    };

    private string TruncateError(string? err) =>
        err != null && err.Length > 40 ? err[..40] + "…" : err ?? "";

    // ── Browser backend profiles (all use standard workload sizes) ──
    private readonly BackendProfile[] _backends = new[]
    {
        new BackendProfile("WebGPU", BenchmarkDefs.StandardProfile.DefaultN, BenchmarkDefs.StandardProfile.MandelbrotSize, BenchmarkDefs.StandardProfile.PrimesN),
        new BackendProfile("WebGL", BenchmarkDefs.StandardProfile.DefaultN, BenchmarkDefs.StandardProfile.MandelbrotSize, BenchmarkDefs.StandardProfile.PrimesN),
        new BackendProfile("Wasm", BenchmarkDefs.StandardProfile.DefaultN, BenchmarkDefs.StandardProfile.MandelbrotSize, BenchmarkDefs.StandardProfile.PrimesN),
    };

    // ====================================================================
    //  BACKEND FACTORY (Browser backends)
    // ====================================================================

    private async Task<(global::ILGPU.Context ctx, Accelerator acc)?> CreateBackend(string name)
    {
        try
        {
            switch (name)
            {
                case "WebGPU":
                {
                    var ctx = await global::ILGPU.Context.CreateAsync(b => b.WebGPU());
                    var devices = ctx.GetWebGPUDevices();
                    if (devices.Count == 0) { ctx.Dispose(); return null; }
                    var acc = await devices[0].CreateAcceleratorAsync(ctx);
                    return (ctx, acc);
                }
                case "WebGL":
                {
                    var ctx = await global::ILGPU.Context.CreateAsync(b => b.WebGL());
                    var devices = ctx.GetWebGLDevices();
                    if (devices.Count == 0) { ctx.Dispose(); return null; }
                    var acc = await devices[0].CreateAcceleratorAsync(ctx);
                    return (ctx, acc);
                }
                case "Wasm":
                {
                    var ctx = await global::ILGPU.Context.CreateAsync(b => b.Wasm());
                    var device = ctx.GetWasmDevice();
                    if (device == null) { ctx.Dispose(); return null; }
                    var acc = await device.CreateAcceleratorAsync(ctx);
                    return (ctx, acc);
                }
                default:
                    return null;
            }
        }
        catch
        {
            return null;
        }
    }

    // ====================================================================
    //  ORCHESTRATOR
    // ====================================================================

    private async Task RunAllBenchmarks()
    {
        _isRunning = true;
        _hasError = false;
        _results.Clear();
        _statusMessage = "Starting benchmarks...";
        StateHasChanged();
        await Task.Delay(50); // let UI render

        int totalSteps = BenchmarkDefs.All.Length * _backends.Length;
        int step = 0;

        foreach (var bench in BenchmarkDefs.All)
        {
            foreach (var backend in _backends)
            {
                step++;
                _progressPercent = (int)(100.0 * step / totalSteps);
                _progressLabel = $"{bench.Name} → {backend.Name} ({step}/{totalSteps})";
                _statusMessage = _progressLabel;
                _currentBackend = backend.Name;
                StateHasChanged();
                await Task.Delay(1); // yield to UI

                var result = await RunSingleBenchmark(bench, backend);
                _results.Add(result);
                StateHasChanged();
                await Task.Delay(1);
            }

            // Draw chart after each benchmark completes for all backends
            StateHasChanged();
            await Task.Delay(50);
            DrawChart(bench);
        }

        _isRunning = false;
        _currentBackend = "";
        _statusMessage = $"Done — {_results.Count(r => !r.Failed)} of {_results.Count} benchmarks succeeded";
        _progressPercent = 100;
        StateHasChanged();
    }

    // ====================================================================
    //  SINGLE BENCHMARK RUNNER — delegates to shared BenchmarkRunner
    // ====================================================================

    private async Task<BenchmarkResult> RunSingleBenchmark(BenchmarkDef bench, BackendProfile backend)
    {
        (global::ILGPU.Context ctx, Accelerator acc)? pair = null;
        try
        {
            pair = await CreateBackend(backend.Name);
            if (pair == null)
                return new BenchmarkResult { BackendName = backend.Name, BenchmarkName = bench.Id, Failed = true, Error = "Backend unavailable" };

            var (ctx, acc) = pair.Value;
            return await BenchmarkRunner.RunAsync(acc, bench.Id, backend);
        }
        catch (Exception ex)
        {
            return new BenchmarkResult
            {
                BackendName = backend.Name,
                BenchmarkName = bench.Id,
                Failed = true,
                Error = ex.Message,
            };
        }
        finally
        {
            if (pair.HasValue)
            {
                pair.Value.acc.Dispose();
                pair.Value.ctx.Dispose();
            }
        }
    }

    // ====================================================================
    //  CHART DRAWING (Canvas2D via JS interop)
    // ====================================================================

    private void DrawChart(BenchmarkDef bench)
    {
        var benchResults = _results
            .Where(r => r.BenchmarkName == bench.Id && r.MedianMs.HasValue)
            .OrderBy(r => System.Array.FindIndex(_backends, b => b.Name == r.BackendName))
            .ToList();

        if (benchResults.Count == 0) return;

        var labels = benchResults.Select(r => r.BackendName).ToArray();
        var values = benchResults.Select(r => r.ThroughputElemPerSec).ToArray();
        var colors = benchResults.Select(r => GetBackendColor(r.BackendName)).ToArray();

        try
        {
            var js = BlazorJSRuntime.JS;
            using var document = js.Get<Document>("document");
            using var canvasEl = document.GetElementById<HTMLCanvasElement>($"chart-{bench.Id}");
            if (canvasEl == null) return;

            using var ctx = canvasEl.Get2DContext();
            if (ctx == null) return;

            using var window = js.Get<Window>("window");
            double dpr = window.DevicePixelRatio;
            double w = canvasEl.ClientWidth;
            double h = canvasEl.ClientHeight;
            canvasEl.Width = (int)(w * dpr);
            canvasEl.Height = (int)(h * dpr);
            ctx.Scale(dpr, dpr);
            ctx.ClearRect(0, 0, w, h);

            double padL = 72, padR = 20, padT = 20, padB = 40;
            double chartW = w - padL - padR;
            double chartH = h - padT - padB;
            double maxVal = values.Max() * 1.15;
            double barW = Math.Min(60, chartW / labels.Length * 0.6);
            double gap = (chartW - barW * labels.Length) / (labels.Length + 1);

            // Grid lines
            ctx.StrokeStyle = "rgba(255,255,255,0.06)";
            ctx.LineWidth = 1;
            for (int g = 0; g <= 4; g++)
            {
                double gy = padT + chartH - (chartH * g / 4.0);
                ctx.BeginPath();
                ctx.MoveTo(padL, gy);
                ctx.LineTo(w - padR, gy);
                ctx.Stroke();

                ctx.FillStyle = "#64748b";
                ctx.Font = "11px sans-serif";
                ctx.TextAlign = "right";
                ctx.FillText(BenchmarkRunner.FormatShortThroughput(maxVal * g / 4.0), padL - 6, gy + 4);
            }

            // Bars
            for (int i = 0; i < labels.Length; i++)
            {
                double x = padL + gap + i * (barW + gap);
                double barH = (values[i] / maxVal) * chartH;
                double y = padT + chartH - barH;

                // Gradient fill
                using var grad = ctx.CreateLinearGradient(x, y, x, padT + chartH);
                grad.AddColorStop(0, colors[i]);
                grad.AddColorStop(1, colors[i] + "33");
                ctx.SetFillStyle(grad);

                // Rounded rect
                double r = 4;
                ctx.BeginPath();
                ctx.MoveTo(x + r, y);
                ctx.LineTo(x + barW - r, y);
                ctx.QuadraticCurveTo(x + barW, y, x + barW, y + r);
                ctx.LineTo(x + barW, padT + chartH);
                ctx.LineTo(x, padT + chartH);
                ctx.LineTo(x, y + r);
                ctx.QuadraticCurveTo(x, y, x + r, y);
                ctx.Fill();

                // Value label above bar
                ctx.FillStyle = "#e2e8f0";
                ctx.Font = "bold 11px sans-serif";
                ctx.TextAlign = "center";
                ctx.FillText(BenchmarkRunner.FormatShortThroughput(values[i]), x + barW / 2, y - 6);

                // Axis label
                ctx.FillStyle = "#94a3b8";
                ctx.Font = "12px sans-serif";
                ctx.FillText(labels[i], x + barW / 2, padT + chartH + 20);
            }

            // Y-axis label
            ctx.Save();
            ctx.Translate(14, padT + chartH / 2);
            ctx.Rotate(-Math.PI / 2);
            ctx.FillStyle = "#64748b";
            ctx.Font = "11px sans-serif";
            ctx.TextAlign = "center";
            ctx.FillText("Throughput (elem/s)", 0, 0);
            ctx.Restore();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chart draw error: {ex.Message}");
        }
    }

    // ── Disposal ──
    public async ValueTask DisposeAsync() { }
}
