    .btn-run {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.7rem 2rem; border: none; border-radius: 8px;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: #fff;
        font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.2s;
    }
    .btn-run:hover:not(.disabled) { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(139,92,246,0.35); }
    .btn-run.disabled { opacity: 0.6; cursor: not-allowed; }
    .spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.6s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .status-pill { padding: 0.35rem 1rem; border-radius: 999px; font-size: 0.85rem; font-weight: 500; }
    .status-info { background: rgba(59,130,246,0.15); color: #93c5fd; }
    .status-error { background: rgba(239,68,68,0.15); color: #fca5a5; }

    /* ── Progress ── */
    .progress-section { margin-bottom: 1.5rem; }
    .progress-bar-track { height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #3b82f6, #a855f7); transition: width 0.3s ease; border-radius: 3px; }
    .progress-label { font-size: 0.8rem; color: #94a3b8; margin-top: 0.3rem; text-align: center; }

    /* ── Cards ── */
    .bench-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;
        transition: border-color 0.2s;
    }
    .bench-card:hover { border-color: rgba(139,92,246,0.25); }
    .bench-card-header { margin-bottom: 1rem; }
    .bench-card-header h2 { font-size: 1.2rem; margin: 0 0 0.2rem; }
    .bench-card-desc { font-size: 0.85rem; color: #94a3b8; }

    /* ── Table ── */
    .bench-table-wrap { overflow-x: auto; margin-bottom: 1rem; }
    .bench-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    .bench-table th { text-align: left; padding: 0.5rem 0.7rem; color: #94a3b8; font-weight: 600; border-bottom: 1px solid rgba(255,255,255,0.08); white-space: nowrap; }
    .bench-table td { padding: 0.5rem 0.7rem; border-bottom: 1px solid rgba(255,255,255,0.04); white-space: nowrap; }
    .row-best td { background: rgba(34,197,94,0.06); }
    .row-failed td { opacity: 0.6; }
    .backend-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 0.4rem; vertical-align: middle; }
    .status-badge { font-size: 0.78rem; padding: 2px 8px; border-radius: 4px; }
    .badge-ok { background: rgba(34,197,94,0.12); color: #4ade80; }
    .badge-fail { background: rgba(239,68,68,0.12); color: #fca5a5; }

    /* ── Chart ── */
    .bench-chart { width: 100%; max-width: 700px; height: 260px; display: block; margin: 0 auto; }

    /* ── Summary ── */
    .summary-card h2 { font-size: 1.3rem; margin: 0 0 1rem; }
    .ranking-grid { display: flex; flex-direction: column; gap: 0.6rem; }
    .rank-item { display: flex; align-items: center; gap: 0.7rem; padding: 0.5rem 0.8rem; background: rgba(255,255,255,0.03); border-radius: 8px; }
    .rank-number { font-weight: 700; color: #a855f7; min-width: 2rem; }
    .rank-name { font-weight: 600; flex: 1; }
    .rank-wins { color: #facc15; font-weight: 600; }
    .rank-avg { color: #94a3b8; font-size: 0.85rem; }
</style>

@* ========================== CODE ========================== *@
@code {
    // ── State ──
    private bool _isRunning;
    private bool _hasError;
    private string _statusMessage = "";
    private string _progressLabel = "";
    private int _progressPercent;
    private readonly List<BenchmarkResult> _results = new();

    // ── Backend colors ──
    private static string GetBackendColor(string name) => name switch
    {
        "WebGPU" => "#22c55e",
        "Workers" => "#3b82f6",
        "Wasm" => "#a855f7",
        "WebGL" => "#f97316",
        "CPU" => "#64748b",
        _ => "#94a3b8"
    };

    private string TruncateError(string? err) =>
        err != null && err.Length > 40 ? err[..40] + "…" : err ?? "";

    // ── Benchmark definitions ──
    private record BenchmarkDef(string Id, string Name, string Icon, string Description);
    private readonly BenchmarkDef[] _benchmarkDefs = new[]
    {
        new BenchmarkDef("vecadd", "Vector Add", "➕", "a[i] = b[i] + c[i] — raw memory throughput"),
        new BenchmarkDef("vecscale", "Vector Scale", "✖", "a[i] = a[i] * scalar — scalar argument marshaling"),
        new BenchmarkDef("saxpy", "SAXPY", "📐", "a[i] = alpha * x[i] + y[i] — classic GPU benchmark"),
        new BenchmarkDef("mandelbrot", "Mandelbrot", "🎨", "512×512 fractal, 200 iterations — compute-bound"),
        new BenchmarkDef("primes", "Prime Count", "🔢", "Count primes up to N using trial division — integer ALU-heavy"),
    };

    // ── Result record ──
    private record BenchmarkResult
    {
        public string BackendName { get; init; } = "";
        public string BenchmarkName { get; init; } = "";
        public double? MedianMs { get; init; }
        public string? Throughput { get; init; }
        public int ElementCount { get; init; }
        public bool Failed { get; init; }
        public string? Error { get; init; }
    }

    // ── Backend descriptors ──
    private record BackendInfo(string Name, int DefaultN, int MandelbrotSize);
    private readonly BackendInfo[] _backends = new[]
    {
        new BackendInfo("WebGPU", 1_000_000, 512),
        new BackendInfo("Workers", 1_000_000, 512),
        new BackendInfo("Wasm", 1_000_000, 512),
        new BackendInfo("WebGL", 1_000_000, 512),
        new BackendInfo("CPU", 65_536, 256),
    };

    // ====================================================================
    //  KERNELS
    // ====================================================================

    private static void VectorAddKernel(Index1D index, ArrayView<float> a, ArrayView<float> b, ArrayView<float> c)
    {
        c[index] = a[index] + b[index];
    }

    private static void VectorScaleKernel(Index1D index, ArrayView<float> a, float scalar)
    {
        a[index] = a[index] * scalar;
    }

    private static void SaxpyKernel(Index1D index, ArrayView<float> y, ArrayView<float> x, float alpha)
    {
        y[index] = alpha * x[index] + y[index];
    }

    private static void MandelbrotKernel(Index1D index, ArrayView<int> output, int width, int height, int maxIter)
    {
        int px = index % width;
        int py = index / width;
        float x0 = (px / (float)width) * 3.5f - 2.5f;
        float y0 = (py / (float)height) * 2.0f - 1.0f;
        float x = 0, y = 0;
        int iter = 0;
        while (x * x + y * y <= 4.0f && iter < maxIter)
        {
            float xtemp = x * x - y * y + x0;
            y = 2.0f * x * y + y0;
            x = xtemp;
            iter++;
        }
        output[index] = iter;
    }

    private static void PrimeCountKernel(Index1D index, ArrayView<int> results, int offset)
    {
        int n = offset + index;
        if (n < 2) { results[index] = 0; return; }
        if (n < 4) { results[index] = 1; return; }
        if (n % 2 == 0) { results[index] = 0; return; }
        for (int d = 3; d * d <= n; d += 2)
        {
            if (n % d == 0) { results[index] = 0; return; }
        }
        results[index] = 1;
    }

    // ====================================================================
    //  BACKEND FACTORY
    // ====================================================================

    private async Task<(global::ILGPU.Context ctx, Accelerator acc)?> CreateBackend(string name)
    {
        try
        {
            switch (name)
            {
                case "WebGPU":
                {
                    var ctx = await global::ILGPU.Context.CreateAsync(b => b.WebGPU());
                    var devs = ctx.GetWebGPUDevices();
                    if (devs.Count == 0) { ctx.Dispose(); return null; }
                    var acc = await devs[0].CreateAcceleratorAsync(ctx);
                    return (ctx, acc);
                }
                case "Workers":
                {
                    var ctx = await global::ILGPU.Context.CreateAsync(b => b.Workers());
                    var devs = ctx.GetDevices<WorkersILGPUDevice>();
                    if (devs.Count == 0) { ctx.Dispose(); return null; }
                    var acc = await devs[0].CreateAcceleratorAsync(ctx);
                    return (ctx, acc);
                }
                case "Wasm":
                {
                    var ctx = await global::ILGPU.Context.CreateAsync(b => b.Wasm());
                    var devs = ctx.GetDevices<WasmILGPUDevice>();
                    if (devs.Count == 0) { ctx.Dispose(); return null; }
                    var acc = await devs[0].CreateAcceleratorAsync(ctx);
                    return (ctx, acc);
                }
                case "WebGL":
                {
                    var ctx = await global::ILGPU.Context.CreateAsync(b => b.WebGL());
                    var devs = ctx.GetWebGLDevices();
                    if (devs.Count == 0) { ctx.Dispose(); return null; }
                    var acc = devs[0].CreateAccelerator(ctx);
                    return (ctx, acc);
                }
                case "CPU":
                {
                    var device = new CPUDevice(numThreadsPerWarp: 4, numWarpsPerMultiprocessor: 16, numMultiprocessors: 1);
                    var ctx = global::ILGPU.Context.Create().CPU(device).ToContext();
                    var acc = ctx.CreateCPUAccelerator(0);
                    return (ctx, acc);
                }
                default:
                    return null;
            }
        }
        catch
        {
            return null;
        }
    }

    // ====================================================================
    //  ORCHESTRATOR
    // ====================================================================

    private async Task RunAllBenchmarks()
    {
        _isRunning = true;
        _hasError = false;
        _results.Clear();
        _statusMessage = "Starting benchmarks...";
        StateHasChanged();
        await Task.Delay(50); // let UI render

        int totalSteps = _benchmarkDefs.Length * _backends.Length;
        int step = 0;

        foreach (var bench in _benchmarkDefs)
        {
            foreach (var backend in _backends)
            {
                step++;
                _progressPercent = (int)(100.0 * step / totalSteps);
                _progressLabel = $"{bench.Name} → {backend.Name} ({step}/{totalSteps})";
                _statusMessage = _progressLabel;
                StateHasChanged();
                await Task.Delay(1); // yield to UI

                var result = await RunSingleBenchmark(bench, backend);
                _results.Add(result);
                StateHasChanged();
                await Task.Delay(1);
            }

            // Draw chart after each benchmark completes for all backends
            StateHasChanged();
            await Task.Delay(50);
            await DrawChart(bench);
        }

        _isRunning = false;
        _statusMessage = $"Done — {_results.Count(r => !r.Failed)} of {_results.Count} benchmarks succeeded";
        _progressPercent = 100;
        StateHasChanged();
    }

    // ====================================================================
    //  SINGLE BENCHMARK RUNNER
    // ====================================================================

    private const int WarmUpIterations = 2;
    private const int MeasuredIterations = 5;

    private async Task<BenchmarkResult> RunSingleBenchmark(BenchmarkDef bench, BackendInfo backend)
    {
        (global::ILGPU.Context ctx, Accelerator acc)? pair = null;
        try
        {
            pair = await CreateBackend(backend.Name);
            if (pair == null)
                return new BenchmarkResult { BackendName = backend.Name, BenchmarkName = bench.Name, Failed = true, Error = "Backend unavailable" };

            var (ctx, acc) = pair.Value;

            var times = bench.Id switch
            {
                "vecadd" => await BenchVectorAdd(acc, backend),
                "vecscale" => await BenchVectorScale(acc, backend),
                "saxpy" => await BenchSaxpy(acc, backend),
                "mandelbrot" => await BenchMandelbrot(acc, backend),
                "primes" => await BenchPrimes(acc, backend),
                _ => throw new ArgumentException($"Unknown benchmark: {bench.Id}")
            };

            int elementCount = bench.Id == "mandelbrot"
                ? backend.MandelbrotSize * backend.MandelbrotSize
                : backend.DefaultN;

            double median = Median(times);
            double throughput = elementCount / (median / 1000.0);
            string throughputStr = FormatThroughput(throughput, bench.Id == "mandelbrot" ? "px" : "elem");

            return new BenchmarkResult
            {
                BackendName = backend.Name,
                BenchmarkName = bench.Name,
                MedianMs = Math.Round(median, 2),
                Throughput = throughputStr,
                ElementCount = elementCount,
            };
        }
        catch (Exception ex)
        {
            return new BenchmarkResult
            {
                BackendName = backend.Name,
                BenchmarkName = bench.Name,
                Failed = true,
                Error = ex.Message,
            };
        }
        finally
        {
            if (pair.HasValue)
            {
                pair.Value.acc.Dispose();
                pair.Value.ctx.Dispose();
            }
        }
    }

    // ====================================================================
    //  INDIVIDUAL BENCHMARKS
    // ====================================================================

    private async Task<double[]> BenchVectorAdd(Accelerator acc, BackendInfo backend)
    {
        int n = backend.DefaultN;
        var a = Enumerable.Range(0, n).Select(i => (float)i).ToArray();
        var b = Enumerable.Range(0, n).Select(i => (float)(i * 2)).ToArray();
        var c = new float[n];

        using var bufA = acc.Allocate1D(a);
        using var bufB = acc.Allocate1D(b);
        using var bufC = acc.Allocate1D(c);

        var kernel = acc.LoadAutoGroupedStreamKernel<Index1D, ArrayView<float>, ArrayView<float>, ArrayView<float>>(VectorAddKernel);

        // Warm up
        for (int i = 0; i < WarmUpIterations; i++)
        {
            kernel((Index1D)n, bufA.View, bufB.View, bufC.View);
            await acc.SynchronizeAsync();
        }

        // Measure
        var times = new double[MeasuredIterations];
        for (int i = 0; i < MeasuredIterations; i++)
        {
            var sw = Stopwatch.StartNew();
            kernel((Index1D)n, bufA.View, bufB.View, bufC.View);
            await acc.SynchronizeAsync();
            sw.Stop();
            times[i] = sw.Elapsed.TotalMilliseconds;
            if (backend.Name == "CPU") await Task.Delay(1); // yield UI
        }
        return times;
    }

    private async Task<double[]> BenchVectorScale(Accelerator acc, BackendInfo backend)
    {
        int n = backend.DefaultN;
        var a = Enumerable.Range(0, n).Select(i => (float)i).ToArray();

        using var bufA = acc.Allocate1D(a);

        var kernel = acc.LoadAutoGroupedStreamKernel<Index1D, ArrayView<float>, float>(VectorScaleKernel);

        for (int i = 0; i < WarmUpIterations; i++)
        {
            kernel((Index1D)n, bufA.View, 2.0f);
            await acc.SynchronizeAsync();
        }

        var times = new double[MeasuredIterations];
        for (int i = 0; i < MeasuredIterations; i++)
        {
            var sw = Stopwatch.StartNew();
            kernel((Index1D)n, bufA.View, 2.0f);
            await acc.SynchronizeAsync();
            sw.Stop();
            times[i] = sw.Elapsed.TotalMilliseconds;
            if (backend.Name == "CPU") await Task.Delay(1);
        }
        return times;
    }

    private async Task<double[]> BenchSaxpy(Accelerator acc, BackendInfo backend)
    {
        int n = backend.DefaultN;
        var x = Enumerable.Range(0, n).Select(i => (float)i).ToArray();
        var y = Enumerable.Range(0, n).Select(i => (float)(i * 0.5)).ToArray();

        using var bufX = acc.Allocate1D(x);
        using var bufY = acc.Allocate1D(y);

        var kernel = acc.LoadAutoGroupedStreamKernel<Index1D, ArrayView<float>, ArrayView<float>, float>(SaxpyKernel);

        for (int i = 0; i < WarmUpIterations; i++)
        {
            kernel((Index1D)n, bufY.View, bufX.View, 2.5f);
            await acc.SynchronizeAsync();
        }

        var times = new double[MeasuredIterations];
        for (int i = 0; i < MeasuredIterations; i++)
        {
            var sw = Stopwatch.StartNew();
            kernel((Index1D)n, bufY.View, bufX.View, 2.5f);
            await acc.SynchronizeAsync();
            sw.Stop();
            times[i] = sw.Elapsed.TotalMilliseconds;
            if (backend.Name == "CPU") await Task.Delay(1);
        }
        return times;
    }

    private async Task<double[]> BenchMandelbrot(Accelerator acc, BackendInfo backend)
    {
        int size = backend.MandelbrotSize;
        int totalPixels = size * size;
        var output = new int[totalPixels];

        using var buf = acc.Allocate1D(output);

        var kernel = acc.LoadAutoGroupedStreamKernel<Index1D, ArrayView<int>, int, int, int>(MandelbrotKernel);

        for (int i = 0; i < WarmUpIterations; i++)
        {
            kernel((Index1D)totalPixels, buf.View, size, size, 200);
            await acc.SynchronizeAsync();
        }

        var times = new double[MeasuredIterations];
        for (int i = 0; i < MeasuredIterations; i++)
        {
            var sw = Stopwatch.StartNew();
            kernel((Index1D)totalPixels, buf.View, size, size, 200);
            await acc.SynchronizeAsync();
            sw.Stop();
            times[i] = sw.Elapsed.TotalMilliseconds;
            if (backend.Name == "CPU") await Task.Delay(1);
        }
        return times;
    }

    private async Task<double[]> BenchPrimes(Accelerator acc, BackendInfo backend)
    {
        int n = backend.DefaultN;
        var results = new int[n];

        using var buf = acc.Allocate1D(results);

        var kernel = acc.LoadAutoGroupedStreamKernel<Index1D, ArrayView<int>, int>(PrimeCountKernel);

        for (int i = 0; i < WarmUpIterations; i++)
        {
            kernel((Index1D)n, buf.View, 2);
            await acc.SynchronizeAsync();
        }

        var times = new double[MeasuredIterations];
        for (int i = 0; i < MeasuredIterations; i++)
        {
            var sw = Stopwatch.StartNew();
            kernel((Index1D)n, buf.View, 2);
            await acc.SynchronizeAsync();
            sw.Stop();
            times[i] = sw.Elapsed.TotalMilliseconds;
            if (backend.Name == "CPU") await Task.Delay(1);
        }
        return times;
    }

    // ====================================================================
    //  CHART DRAWING (Canvas2D via JS interop)
    // ====================================================================

    private async Task DrawChart(BenchmarkDef bench)
    {
        var benchResults = _results
            .Where(r => r.BenchmarkName == bench.Name && r.MedianMs.HasValue)
            .OrderBy(r => System.Array.FindIndex(_backends, b => b.Name == r.BackendName))
            .ToList();

        if (benchResults.Count == 0) return;

        var labels = benchResults.Select(r => r.BackendName).ToArray();
        var values = benchResults.Select(r => r.MedianMs!.Value).ToArray();
        var colors = benchResults.Select(r => GetBackendColor(r.BackendName)).ToArray();

        try
        {
            await JSRuntime.InvokeVoidAsync("eval", $@"
            (function() {{
                var canvas = document.getElementById('chart-{bench.Id}');
                if (!canvas) return;
                var ctx = canvas.getContext('2d');
                var dpr = window.devicePixelRatio || 1;
                var w = canvas.clientWidth;
                var h = canvas.clientHeight;
                canvas.width = w * dpr;
                canvas.height = h * dpr;
                ctx.scale(dpr, dpr);
                ctx.clearRect(0, 0, w, h);

                var labels = {System.Text.Json.JsonSerializer.Serialize(labels)};
                var values = {System.Text.Json.JsonSerializer.Serialize(values)};
                var colors = {System.Text.Json.JsonSerializer.Serialize(colors)};

                var padL = 60, padR = 20, padT = 20, padB = 40;
                var chartW = w - padL - padR;
                var chartH = h - padT - padB;
                var maxVal = Math.max(...values) * 1.15;
                var barW = Math.min(60, chartW / labels.length * 0.6);
                var gap = (chartW - barW * labels.length) / (labels.length + 1);

                // grid lines
                ctx.strokeStyle = 'rgba(255,255,255,0.06)';
                ctx.lineWidth = 1;
                for (var g = 0; g <= 4; g++) {{
                    var gy = padT + chartH - (chartH * g / 4);
                    ctx.beginPath(); ctx.moveTo(padL, gy); ctx.lineTo(w - padR, gy); ctx.stroke();
                    ctx.fillStyle = '#64748b'; ctx.font = '11px sans-serif'; ctx.textAlign = 'right';
                    ctx.fillText((maxVal * g / 4).toFixed(1), padL - 6, gy + 4);
                }}

                // bars
                for (var i = 0; i < labels.length; i++) {{
                    var x = padL + gap + i * (barW + gap);
                    var barH = (values[i] / maxVal) * chartH;
                    var y = padT + chartH - barH;

                    // gradient fill
                    var grad = ctx.createLinearGradient(x, y, x, padT + chartH);
                    grad.addColorStop(0, colors[i]);
                    grad.addColorStop(1, colors[i] + '33');
                    ctx.fillStyle = grad;

                    // rounded rect
                    var r = 4;
                    ctx.beginPath();
                    ctx.moveTo(x + r, y);
                    ctx.lineTo(x + barW - r, y);
                    ctx.quadraticCurveTo(x + barW, y, x + barW, y + r);
                    ctx.lineTo(x + barW, padT + chartH);
                    ctx.lineTo(x, padT + chartH);
                    ctx.lineTo(x, y + r);
                    ctx.quadraticCurveTo(x, y, x + r, y);
                    ctx.fill();

                    // value label
                    ctx.fillStyle = '#e2e8f0'; ctx.font = 'bold 11px sans-serif'; ctx.textAlign = 'center';
                    ctx.fillText(values[i].toFixed(1) + ' ms', x + barW / 2, y - 6);

                    // axis label
                    ctx.fillStyle = '#94a3b8'; ctx.font = '12px sans-serif';
                    ctx.fillText(labels[i], x + barW / 2, padT + chartH + 20);
                }}

                // y-axis label
                ctx.save(); ctx.translate(14, padT + chartH / 2); ctx.rotate(-Math.PI / 2);
                ctx.fillStyle = '#64748b'; ctx.font = '11px sans-serif'; ctx.textAlign = 'center';
                ctx.fillText('Time (ms)', 0, 0);
                ctx.restore();
            }})();
            ");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chart draw error: {ex.Message}");
        }
    }

    // ====================================================================
    //  HELPERS
    // ====================================================================

    private static double Median(double[] values)
    {
        var sorted = values.OrderBy(v => v).ToArray();
        int mid = sorted.Length / 2;
        return sorted.Length % 2 == 0 ? (sorted[mid - 1] + sorted[mid]) / 2.0 : sorted[mid];
    }

    private static string FormatThroughput(double elemPerSec, string unit)
    {
        if (elemPerSec >= 1_000_000_000) return $"{elemPerSec / 1e9:F2} G{unit}/s";
        if (elemPerSec >= 1_000_000) return $"{elemPerSec / 1e6:F2} M{unit}/s";
        if (elemPerSec >= 1_000) return $"{elemPerSec / 1e3:F2} K{unit}/s";
        return $"{elemPerSec:F0} {unit}/s";
    }

