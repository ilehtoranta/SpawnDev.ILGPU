@page "/tests"
@using System.Reflection
@using SpawnDev.UnitTesting.Blazor
@using SpawnDev.ILGPU.WebGPU.Backend

<PageTitle>Unit Tests</PageTitle>

<h3>Unit Tests</h3>

<UnitTestsView TypeInstanceResolver="TestTypeResolver" TestAssemblies="Assemblies" TestTypes="Types"></UnitTestsView>

<hr />
<h4>Last Generated WGSL Source</h4>
<button @onclick="RefreshWGSL">Refresh WGSL</button>
@if (!string.IsNullOrEmpty(_lastWGSL))
{
    <p>Length: @_lastWGSL.Length chars, @_lastWGSL.Split('\n').Length lines</p>
    <pre style="max-height:600px;overflow:auto;background:#1e1e1e;color:#d4d4d4;padding:8px;font-size:12px;white-space:pre;border:1px solid #444;">@_lastWGSL</pre>
}
else
{
    <p><em>No WGSL generated yet. Run a test first, then click Refresh.</em></p>
}

@code{
    [Inject]
    IServiceCollection ServiceDescriptors { get; set; } = default!;
    List<Assembly>? Assemblies = new List<Assembly>();
    List<Type>? Types = new List<Type>();
    object? TestTypeResolver(Type testType)
    {
        if (testType == this.GetType()) return this;
        return null;
    }
    string? _lastWGSL;
    void RefreshWGSL()
    {
        _lastWGSL = WebGPUBackend.LastGeneratedWGSL;
        StateHasChanged();
    }
    protected override void OnInitialized()
    {
        Types = new List<Type> { this.GetType() };
        // add tests in the assembly this is in
        Assemblies = new List<Assembly> { this.GetType().Assembly };
        // add all services. only services with tests will be used.
        // not necessary if the service types are in an assembly that is in the Assemblies list
        foreach (var descriptor in ServiceDescriptors)
        {
            Types.Add(descriptor.ServiceType);
        }
    }
}