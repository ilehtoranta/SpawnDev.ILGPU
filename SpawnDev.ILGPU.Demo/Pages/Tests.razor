@page "/tests"
@using System.Reflection
@using SpawnDev.UnitTesting.Blazor
@using SpawnDev.ILGPU.WebGPU.Backend
@using SpawnDev.ILGPU.WebGL

<PageTitle>Unit Tests</PageTitle>

<h3>Unit Tests</h3>


<hr />
<h4>Shader Debug Output</h4>
<div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:0.5rem;">
    @if (_shaderDebug.HasDebugFolder && _shaderDebug.HasWritePermission)
    {
        <span style="color:green;">Auto-dumping to: <strong>@_shaderDebug.FolderName</strong></span>
        <button @onclick="() => { _shaderDebug.ClearAsync(); StateHasChanged(); }">Clear</button>
    }
    else if (_shaderDebug.NeedsPermissionGrant)
    {
        <span style="color:orange;">Debug folder: <strong>@_shaderDebug.FolderName</strong> (needs write access)</span>
        <button @onclick="GrantWriteAccess">Grant Write Access</button>
        <button @onclick="() => { _shaderDebug.ClearAsync(); StateHasChanged(); }">Clear</button>
    }
    else
    {
        <button @onclick="PickDebugFolder">Set Debug Folder</button>
        <span style="color:gray;font-size:0.85rem;">Pick folder to write WGSL/GLSL/Wasm to disk</span>
    }
</div>
<hr />

<UnitTestsView TypeInstanceResolver="TestTypeResolver" TestAssemblies="Assemblies" TestTypes="Types" ResultsDirectory="_shaderDebug.DebugDirectory"></UnitTestsView>

@* 
@if (_dumpStatus != null) { <span style="color:green;">@_dumpStatus</span> }
<hr />
<h4>Generated WGSL Sources</h4>
<button @onclick="RefreshWGSL">Refresh WGSL</button>
<button @onclick="ClearWGSL">Clear WGSL List</button>
<button @onclick="CopyAllWGSL">Copy All to Clipboard</button>
@if (_copyStatus != null) { <span style="color:green;margin-left:8px;">@_copyStatus</span> }
@if (_allWGSL != null && _allWGSL.Count > 0)
{
    <p>Total shaders: @_allWGSL.Count</p>
    @for (int idx = 0; idx < _allWGSL.Count; idx++)
    {
        var shader = _allWGSL[idx];
        <details>
            <summary>Shader @(idx + 1) (@shader.Split('\n').Length lines, @shader.Length chars)</summary>
            <pre style="max-height:600px;overflow:auto;background:#1e1e1e;color:#d4d4d4;padding:8px;font-size:12px;white-space:pre;border:1px solid #444;">@shader</pre>
        </details>
    }
}
else
{
    <p><em>No WGSL generated yet. Run a test first, then click Refresh.</em></p>
}

<hr />
<h4>Last Generated GLSL Source (WebGL)</h4>
<button @onclick="RefreshGLSL">Refresh GLSL</button>
@if (!string.IsNullOrEmpty(_lastGLSL))
{
    <p>Length: @_lastGLSL.Length chars, @_lastGLSL.Split('\n').Length lines</p>
    <pre style="max-height:600px;overflow:auto;background:#1e1e1e;color:#d4d4d4;padding:8px;font-size:12px;white-space:pre;border:1px solid #444;">@_lastGLSL</pre>
}
else
{
    <p><em>No GLSL generated yet. Run a WebGL test first, then click Refresh.</em></p>
} *@

@inject SpawnDev.BlazorJS.BlazorJSRuntime JS
@inject SpawnDev.ILGPU.Services.ShaderDebugService _shaderDebug

@code{
    [Inject]
    IServiceCollection ServiceDescriptors { get; set; } = default!;
    string? _copyStatus;
    string? _dumpStatus;

    async Task PickDebugFolder() { if (await _shaderDebug.PickFolderAsync()) StateHasChanged(); }
    async Task GrantWriteAccess() { await _shaderDebug.RequestWritePermissionAsync(); StateHasChanged(); }
    List<Assembly>? Assemblies = new List<Assembly>();
    List<Type>? Types = new List<Type>();
    object? TestTypeResolver(Type testType)
    {
        if (testType == this.GetType()) return this;
        return null;
    }
    List<string>? _allWGSL;
    void RefreshWGSL()
    {
        _allWGSL = new List<string>(WebGPUBackend.AllGeneratedWGSL);
        StateHasChanged();
    }
    void ClearWGSL()
    {
        WebGPUBackend.AllGeneratedWGSL.Clear();
        _allWGSL = null;
        _copyStatus = null;
        StateHasChanged();
    }
    async Task CopyAllWGSL()
    {
        RefreshWGSL();
        if (_allWGSL == null || _allWGSL.Count == 0)
        {
            _copyStatus = "No shaders to copy";
            return;
        }
        var sb = new System.Text.StringBuilder();
        var registry = WebGPUBackend.WGSLRegistry;
        if (registry.Count > 0)
        {
            foreach (var (name, entry) in registry)
            {
                sb.AppendLine($"// ═══ Kernel: {name} ═══");
                sb.AppendLine(entry.Source);
                sb.AppendLine();
            }
        }
        else
        {
            for (int i = 0; i < _allWGSL.Count; i++)
            {
                sb.AppendLine($"// ═══ Shader {i + 1} of {_allWGSL.Count} ═══");
                sb.AppendLine(_allWGSL[i]);
                sb.AppendLine();
            }
        }
        try
        {
            using var navigator = JS.Get<SpawnDev.BlazorJS.JSObjects.Navigator>("navigator");
            using var clipboard = navigator.Clipboard;
            await clipboard.WriteText(sb.ToString());
            _copyStatus = $"Copied {(registry.Count > 0 ? registry.Count : _allWGSL.Count)} shaders!";
        }
        catch (Exception ex)
        {
            _copyStatus = $"Copy failed: {ex.Message}";
        }
        StateHasChanged();
    }
    string? _lastGLSL;
    void RefreshGLSL()
    {
        _lastGLSL = WebGLAccelerator.LastGeneratedGLSL;
        StateHasChanged();
    }
    protected override void OnInitialized()
    {
        Types = new List<Type> { this.GetType() };
        // add tests in the assembly this is in
        Assemblies = new List<Assembly> { this.GetType().Assembly };
        // add all services. only services with tests will be used.
        // not necessary if the service types are in an assembly that is in the Assemblies list
        foreach (var descriptor in ServiceDescriptors)
        {
            Types.Add(descriptor.ServiceType);
        }
    }
}