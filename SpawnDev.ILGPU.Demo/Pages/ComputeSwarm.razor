    private async Task ChangeKeyRole(string publicKey, ChangeEventArgs e)
    {
        if (_compute?.Coordinator.Registry == null || e.Value == null) return;
        var roleName = e.Value.ToString();
        if (string.IsNullOrEmpty(roleName)) return;

        var newRole = Enum.Parse<SwarmRole>(roleName);
        var key = _compute.Coordinator.Registry.Keys.FirstOrDefault(k => k.PublicKey == publicKey);
        if (key != null)
        {
            key.Role = newRole;
            if (_compute.Identity != null)
                await _compute.Coordinator.Registry.SignAsync(_compute.Identity);
            StateHasChanged();
        }
    }

    private async Task RevokeKey(string publicKey)
    {
        if (_compute?.Coordinator.Registry == null) return;
        _compute.Coordinator.Registry.RevokeKey(Convert.FromBase64String(publicKey), "Revoked by coordinator");
        if (_compute.Identity != null)
            await _compute.Coordinator.Registry.SignAsync(_compute.Identity);
        StateHasChanged();
    }

    private static string RoleColor(SwarmRole role) => role switch
    {
        SwarmRole.Owner => "#7c3aed",
        SwarmRole.Admin => "#3b82f6",
        SwarmRole.Coordinator => "#10b981",
        SwarmRole.Worker => "#64748b",
        _ => "#334155",
    };

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024 * 1024):N1} GB";
        if (bytes >= 1024L * 1024) return $"{bytes / (1024.0 * 1024):N0} MB";
        return $"{bytes / 1024.0:N0} KB";
    }

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Stop();
        _refreshTimer?.Dispose();
        _scanTimer?.Stop();
        _scanTimer?.Dispose();

        // Release camera if scanning was active
        if (_cameraStream != null)
        {
            try
            {
                using var tracks = _cameraStream.GetTracks();
                for (int i = 0; i < tracks.Length; i++)
                {
                    using var track = tracks[i];
                    track.Stop();
                }
            }
            catch { }
            _cameraStream.Dispose();
            _cameraStream = null;
        }

        // Don't clear swarm state on dispose — we want to restore on reload.
        // Only ClearSwarmState() when the user explicitly leaves/destroys the swarm.
        if (_compute != null) await _compute.DisposeAsync();
    }
