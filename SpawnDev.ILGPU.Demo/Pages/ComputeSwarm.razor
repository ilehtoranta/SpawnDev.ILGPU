@page "/compute"
@page "/compute/join"
@using SpawnDev.ILGPU
@using SpawnDev.ILGPU.P2P
@using SpawnDev.ILGPU.Demo.Shared
@using SpawnDev.ILGPU.QR
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.Cryptography
@using SpawnDev.BlazorJS.JSObjects
@inject NavigationManager Nav
@inject BlazorJSRuntime JS
@inject IPortableCrypto Crypto
@inject SpawnDev.WebTorrent.WebTorrentClient WebTorrentClient
@inject SpawnDev.ILGPU.Demo.Shared.Services.P2PSwarmService SwarmService
@implements IAsyncDisposable

<PageTitle>P2P Compute Swarm</PageTitle>

<div style="background: #0f172a; color: #e2e8f0; min-height: 100vh; padding: 20px; font-family: -apple-system, sans-serif;">

    @if (_state == SwarmPageState.Loading)
    {
        <h2 style="color: #94a3b8;">Initializing P2P Compute...</h2>
    }
    else if (_state == SwarmPageState.JoinConsent)
    {
        <!-- Join Consent Dialog -->
        <div style="max-width: 500px; margin: 80px auto; background: #1e293b; border-radius: 12px; padding: 32px; text-align: center;">
            <h2 style="color: #f1f5f9; margin-bottom: 8px;">Join Compute Swarm?</h2>
            <p style="color: #94a3b8; font-size: 14px; margin-bottom: 24px;">
                <strong style="color: #10b981;">@_swarmName</strong> wants to use your device for distributed GPU computing.
            </p>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <button @onclick="JoinAlways" style="background: #10b981; color: white; border: none; padding: 12px; border-radius: 8px; font-size: 16px; cursor: pointer; font-weight: bold;">
                    Always Join This Swarm
                </button>
                <button @onclick="JoinOnce" style="background: #3b82f6; color: white; border: none; padding: 12px; border-radius: 8px; font-size: 16px; cursor: pointer;">
                    Join This Time
                </button>
                <button @onclick="Decline" style="background: #334155; color: #94a3b8; border: none; padding: 12px; border-radius: 8px; font-size: 16px; cursor: pointer;">
                    Not Now
                </button>
            </div>
        </div>
    }
    else if (_state == SwarmPageState.Dashboard)
    {
        <!-- Swarm Dashboard -->
        <div style="max-width: 1000px; margin: 0 auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="color: #f1f5f9; margin: 0;">
                    @if (_compute?.Role == P2PRole.Coordinator)
                    {
                        <span style="color: #10b981;">&#9679;</span>
                    }
                    else
                    {
                        <span style="color: #3b82f6;">&#9679;</span>
                    }
                    P2P Compute — @(_compute?.Role.ToString() ?? "Disconnected")
                </h2>
                @if (_compute == null)
                {
                    <button @onclick="CreateSwarm" style="background: #10b981; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                        Create Swarm
                    </button>
                }
                else
                {
                    <button @onclick="LeaveSwarm" style="background: #ef4444; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px;">
                        Leave Swarm
                    </button>
                }
            </div>

            @if (_compute != null)
            {
                <!-- Swarm Resource Overview -->
                <div style="display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;">
                    <div style="background: #1e293b; padding: 16px 20px; border-radius: 8px; flex: 1; min-width: 120px; text-align: center;">
                        <div style="font-size: 28px; font-weight: bold; color: #10b981;">@_compute.PeerCount</div>
                        <div style="font-size: 11px; color: #64748b;">Peers</div>
                    </div>
                    <div style="background: #1e293b; padding: 16px 20px; border-radius: 8px; flex: 1; min-width: 120px; text-align: center;">
                        <div style="font-size: 28px; font-weight: bold; color: #3b82f6;">@_compute.TotalTflops.ToString("N1")</div>
                        <div style="font-size: 11px; color: #64748b;">Total TFLOPS</div>
                    </div>
                    <div style="background: #1e293b; padding: 16px 20px; border-radius: 8px; flex: 1; min-width: 120px; text-align: center;">
                        <div style="font-size: 28px; font-weight: bold; color: #a78bfa;">@FormatBytes(GetTotalMemory())</div>
                        <div style="font-size: 11px; color: #64748b;">Total Memory</div>
                    </div>
                    <div style="background: #1e293b; padding: 16px 20px; border-radius: 8px; flex: 1; min-width: 120px; text-align: center;">
                        <div style="font-size: 28px; font-weight: bold; color: #f59e0b;">@_compute.Role</div>
                        <div style="font-size: 11px; color: #64748b;">Your Role</div>
                    </div>
                    <div style="background: #1e293b; padding: 16px 20px; border-radius: 8px; flex: 1; min-width: 120px; text-align: center;">
                        <div style="font-size: 28px; font-weight: bold; color: @(_dispatching ? "#10b981" : "#334155");">@_dispatchCount</div>
                        <div style="font-size: 11px; color: #64748b;">Dispatches</div>
                    </div>
                    <div style="background: #1e293b; padding: 16px 20px; border-radius: 8px; flex: 1; min-width: 120px; text-align: center;">
                        <div style="font-size: 28px; font-weight: bold; color: @GetVerifiedColor();">@GetVerifiedCount()/@_compute.PeerCount</div>
                        <div style="font-size: 11px; color: #64748b;">Verified</div>
                    </div>
                </div>

                <!-- Join Link -->
                @if (!string.IsNullOrEmpty(_compute.JoinLink))
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                        <div style="font-size: 12px; color: #64748b; margin-bottom: 4px;">Share this link — anyone can join:</div>
                        <div style="font-family: monospace; font-size: 13px; color: #10b981; word-break: break-all; background: #0f172a; padding: 8px; border-radius: 4px;">
                            @_compute.JoinLink
                        </div>
                        <button @onclick="CopyJoinLink" style="background: #334155; color: #94a3b8; border: none; padding: 6px 12px; border-radius: 4px; margin-top: 8px; cursor: pointer; font-size: 12px;">
                            Copy Link
                        </button>
                    </div>
                }

                <!-- Distributed Compute Demo -->
                @if (_compute.Role == P2PRole.Coordinator && _compute.PeerCount > 0)
                {
                    <div style="background: linear-gradient(135deg, #1e293b 0%, #0f2027 100%); padding: 20px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #10b981;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                            <div>
                                <div style="font-size: 16px; color: #f1f5f9; font-weight: bold;">Distributed Compute</div>
                                <div style="font-size: 12px; color: #64748b;">Dispatch work across the swarm and watch fault tolerance in action</div>
                            </div>
                            <button @onclick="RunDistributedBenchmark" disabled="@_benchmarkRunning" style="background: @(_benchmarkRunning ? "#334155" : "#10b981"); color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: @(_benchmarkRunning ? "default" : "pointer"); font-weight: bold; font-size: 14px;">
                                @if (_benchmarkRunning) { <span>Computing...</span> } else { <span>Run Benchmark</span> }
                            </button>
                        </div>

                        @if (_benchmarkTasks.Count > 0)
                        {
                            <!-- Per-Peer Task Grid -->
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; margin-bottom: 16px;">
                                @foreach (var task in _benchmarkTasks)
                                {
                                    var barColor = task.Status switch
                                    {
                                        "Running" => "#3b82f6",
                                        "Complete" => "#10b981",
                                        "Retrying" => "#f59e0b",
                                        "Failed" => "#ef4444",
                                        _ => "#334155"
                                    };
                                    <div style="background: #0f172a; border-radius: 6px; padding: 12px; border-left: 3px solid @barColor;">
                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                                            <span style="font-size: 12px; font-weight: bold; color: #f1f5f9;">Chunk @task.ChunkIndex</span>
                                            <span style="font-size: 10px; padding: 1px 6px; border-radius: 8px; background: @barColor; color: white;">@task.Status</span>
                                        </div>
                                        <div style="font-family: monospace; font-size: 10px; color: #64748b; margin-bottom: 4px;">
                                            Peer: @(task.PeerId?[..Math.Min(10, task.PeerId?.Length ?? 0)] ?? "—")...
                                        </div>
                                        <div style="background: #1e293b; border-radius: 3px; height: 6px; overflow: hidden;">
                                            <div style="background: @barColor; height: 100%; width: @(task.Progress)%; transition: width 0.3s;"></div>
                                        </div>
                                        @if (task.DurationMs > 0)
                                        {
                                            <div style="font-size: 10px; color: #475569; margin-top: 4px;">@task.DurationMs ms | @task.Elements.ToString("N0") elements</div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Aggregate Results -->
                            @if (_benchmarkComplete)
                            {
                                <div style="background: #0f172a; padding: 12px; border-radius: 6px; display: flex; gap: 20px; flex-wrap: wrap;">
                                    <div>
                                        <div style="font-size: 20px; font-weight: bold; color: #10b981;">@_benchmarkTotalTime ms</div>
                                        <div style="font-size: 10px; color: #64748b;">Total Time</div>
                                    </div>
                                    <div>
                                        <div style="font-size: 20px; font-weight: bold; color: #3b82f6;">@_benchmarkTotalElements.ToString("N0")</div>
                                        <div style="font-size: 10px; color: #64748b;">Elements Processed</div>
                                    </div>
                                    <div>
                                        <div style="font-size: 20px; font-weight: bold; color: #a78bfa;">@_benchmarkSuccessCount/@_benchmarkTasks.Count</div>
                                        <div style="font-size: 10px; color: #64748b;">Tasks Succeeded</div>
                                    </div>
                                    <div>
                                        <div style="font-size: 20px; font-weight: bold; color: #f59e0b;">@_benchmarkRetryCount</div>
                                        <div style="font-size: 10px; color: #64748b;">Retries (Fault Tolerance)</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }

                <!-- Distributed Mandelbrot Rendering -->
                @if (_compute != null && _compute.PeerCount > 0)
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #a78bfa;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                            <div>
                                <div style="font-size: 14px; color: #f1f5f9; font-weight: bold;">Distributed Mandelbrot</div>
                                <div style="font-size: 11px; color: #64748b;">Each peer computes a horizontal strip — tiles colored by peer</div>
                            </div>
                            <button @onclick="RunDistributedMandelbrot" disabled="@_mandelbrotRunning" style="background: @(_mandelbrotRunning ? "#334155" : "#a78bfa"); color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                                @if (_mandelbrotRunning) { <span>Rendering...</span> } else { <span>Render</span> }
                            </button>
                        </div>
                        <canvas @ref="_mandelbrotCanvas" width="512" height="512" style="width: 100%; max-width: 512px; height: auto; border-radius: 4px; background: #0f172a; image-rendering: pixelated;"></canvas>
                        @if (_mandelbrotTimeMs > 0)
                        {
                            <div style="margin-top: 8px; font-size: 12px; color: #94a3b8;">
                                Rendered in <strong style="color: #a78bfa;">@_mandelbrotTimeMs.ToString("F0") ms</strong> across <strong>@_compute.PeerCount peers</strong>
                            </div>
                        }
                    </div>
                }

                <!-- QR Code -->
                @if (!string.IsNullOrEmpty(_qrDataUrl))
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
                        <div style="font-size: 12px; color: #64748b; margin-bottom: 8px;">Scan to join from any device:</div>
                        <img src="@_qrDataUrl" style="width: 200px; height: 200px; image-rendering: pixelated; border-radius: 4px;" alt="QR Code" />
                    </div>
                }

                <!-- QR Scanner -->
                @if (_compute == null)
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
                        @if (_scanning)
                        {
                            <div style="font-size: 12px; color: #64748b; margin-bottom: 8px;">Point camera at a QR code to join a swarm:</div>
                            <video @ref="_videoRef" autoplay playsinline muted style="width: 240px; height: 240px; border-radius: 8px; object-fit: cover; background: #000;"></video>
                            <canvas @ref="_scanCanvasRef" width="240" height="240" style="display: none;"></canvas>
                            <div style="margin-top: 8px;">
                                <button @onclick="StopScanning" style="background: #334155; color: #94a3b8; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    Stop Scanning
                                </button>
                            </div>
                            @if (_scanStatus != null)
                            {
                                <div style="margin-top: 4px; font-size: 11px; color: #10b981;">@_scanStatus</div>
                            }
                        }
                        else
                        {
                            <button @onclick="StartScanning" style="background: #3b82f6; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                                Scan QR Code to Join
                            </button>
                        }
                    </div>
                }

                <!-- Magnet Link -->
                @if (!string.IsNullOrEmpty(_compute.MagnetLink))
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                        <div style="font-size: 12px; color: #64748b; margin-bottom: 4px;">Magnet link (for desktop apps):</div>
                        <div style="font-family: monospace; font-size: 11px; color: #475569; word-break: break-all; background: #0f172a; padding: 8px; border-radius: 4px; max-height: 60px; overflow: hidden;">
                            @_compute.MagnetLink
                        </div>
                    </div>
                }

                <!-- Peer List with Reputation -->
                <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                    <div style="font-size: 14px; color: #f1f5f9; font-weight: bold; margin-bottom: 12px;">Connected Peers</div>
                    @if (_compute.Coordinator.GetPeerList().Count == 0)
                    {
                        <div style="color: #475569; font-size: 13px; padding: 20px; text-align: center;">
                            No peers connected. Share the join link to invite devices.
                        </div>
                    }
                    else
                    {
                        <table style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="border-bottom: 1px solid #334155;">
                                    <th style="text-align: left; padding: 6px; color: #64748b; font-size: 11px;">Peer</th>
                                    <th style="text-align: center; padding: 6px; color: #64748b; font-size: 11px;">Trust</th>
                                    <th style="text-align: right; padding: 6px; color: #64748b; font-size: 11px;">TFLOPS</th>
                                    <th style="text-align: right; padding: 6px; color: #64748b; font-size: 11px;">Memory</th>
                                    <th style="text-align: center; padding: 6px; color: #64748b; font-size: 11px;">Backend</th>
                                    <th style="text-align: center; padding: 6px; color: #64748b; font-size: 11px;">Status</th>
                                    @if (_compute.Role == P2PRole.Coordinator)
                                    {
                                        <th style="text-align: center; padding: 6px; color: #64748b; font-size: 11px;">Actions</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var peer in _compute.Coordinator.GetPeerList())
                                {
                                    var trustInfo = GetPeerTrust(peer);
                                    <tr style="border-bottom: 1px solid #1a2332;">
                                        <td style="padding: 8px 6px;">
                                            <div style="font-family: monospace; font-size: 12px; color: #94a3b8;">@peer.PeerId[..Math.Min(12, peer.PeerId.Length)]...</div>
                                            @if (!string.IsNullOrEmpty(peer.Capabilities?.Fingerprint))
                                            {
                                                <div style="font-family: monospace; font-size: 9px; color: #334155; margin-top: 1px;" title="ECDSA Fingerprint">@peer.Capabilities.Fingerprint[..Math.Min(16, peer.Capabilities.Fingerprint.Length)]...</div>
                                            }
                                        </td>
                                        <td style="text-align: center; padding: 8px 6px;">
                                            <div title="@trustInfo.Tooltip">
                                                <span style="font-size: 14px;">@trustInfo.Icon</span>
                                                <div style="font-size: 9px; color: @trustInfo.Color;">@trustInfo.Label</div>
                                                @if (peer.DispatchCount > 0)
                                                {
                                                    <div style="font-size: 9px; color: @(peer.SuccessRate >= 0.9 ? "#10b981" : peer.SuccessRate >= 0.5 ? "#f59e0b" : "#ef4444");">
                                                        @peer.SuccessCount/@peer.DispatchCount (@(peer.SuccessRate * 100):F0%)
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                        <td style="text-align: right; padding: 8px 6px; color: #10b981; font-weight: bold;">@(peer.Capabilities?.EstimatedTflops.ToString("N1") ?? "-")</td>
                                        <td style="text-align: right; padding: 8px 6px; color: #94a3b8; font-size: 12px;">@FormatBytes(peer.Capabilities?.AvailableMemory ?? 0)</td>
                                        <td style="text-align: center; padding: 8px 6px; font-size: 11px;">
                                            <span style="background: #0d2e24; color: #10b981; padding: 2px 8px; border-radius: 10px;">
                                                @(peer.Capabilities?.PreferredBackend ?? "?")
                                            </span>
                                        </td>
                                        <td style="text-align: center; padding: 8px 6px;">
                                            @if (peer.IsConnected)
                                            {
                                                <span style="color: #10b981;">&#9679; Online</span>
                                            }
                                            else
                                            {
                                                <span style="color: #ef4444;">&#9679; Offline</span>
                                            }
                                        </td>
                                        @if (_compute.Role == P2PRole.Coordinator)
                                        {
                                            <td style="text-align: center; padding: 8px 6px;">
                                                <button @onclick="() => KickPeer(peer.PeerId)" style="background: #ef4444; color: white; border: none; padding: 2px 8px; border-radius: 4px; cursor: pointer; font-size: 11px;">Kick</button>
                                                <button @onclick="() => BlockPeer(peer.PeerId)" style="background: #7f1d1d; color: white; border: none; padding: 2px 8px; border-radius: 4px; cursor: pointer; font-size: 11px; margin-left: 4px;">Block</button>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <!-- Swarm Activity Log -->
                <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <div style="font-size: 14px; color: #f1f5f9; font-weight: bold;">Activity</div>
                        @if (_activityLog.Count > 0)
                        {
                            <button @onclick="() => _activityLog.Clear()" style="background: #334155; color: #64748b; border: none; padding: 2px 8px; border-radius: 4px; cursor: pointer; font-size: 10px;">Clear</button>
                        }
                    </div>
                    <div style="max-height: 200px; overflow-y: auto; font-family: monospace; font-size: 11px;">
                        @if (_activityLog.Count == 0)
                        {
                            <div style="color: #475569; text-align: center; padding: 12px;">Waiting for activity...</div>
                        }
                        else
                        {
                            @foreach (var entry in _activityLog.AsEnumerable().Reverse().Take(50))
                            {
                                <div style="padding: 3px 0; border-bottom: 1px solid #0f172a; color: @entry.Color;">
                                    <span style="color: #475569;">@entry.Time.ToString("HH:mm:ss")</span>
                                    <span style="margin-left: 8px;">@entry.Icon</span>
                                    <span style="margin-left: 4px;">@entry.Message</span>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Pending Approvals (Coordinator only, Approval mode) -->
                @if (_compute.Role == P2PRole.Coordinator && _compute.Coordinator.PendingApproval.Count > 0)
                {
                    <div style="background: #1e293b; border: 1px solid #f59e0b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                        <div style="font-size: 14px; color: #f59e0b; font-weight: bold; margin-bottom: 12px;">
                            Pending Approval (@_compute.Coordinator.PendingApproval.Count)
                        </div>
                        @foreach (var pending in _compute.Coordinator.PendingApproval.Values)
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px; background: #0f172a; border-radius: 4px; margin-bottom: 4px;">
                                <div>
                                    <span style="font-family: monospace; font-size: 12px; color: #94a3b8;">@pending.PeerId[..Math.Min(16, pending.PeerId.Length)]...</span>
                                    <span style="font-size: 11px; color: #64748b; margin-left: 8px;">@(pending.Capabilities?.PreferredBackend ?? "?") | @(pending.Capabilities?.EstimatedTflops.ToString("N1") ?? "?") TFLOPS</span>
                                </div>
                                <div style="display: flex; gap: 4px;">
                                    <button @onclick="() => ApprovePeer(pending.PeerId)" style="background: #10b981; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 11px;">Approve</button>
                                    <button @onclick="() => RejectPeer(pending.PeerId)" style="background: #ef4444; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 11px;">Reject</button>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Fault Tolerance Theater (Coordinator only) -->
                @if (_compute?.Role == P2PRole.Coordinator && _compute.PeerCount >= 2)
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #f59e0b;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                            <div>
                                <div style="font-size: 14px; color: #f59e0b; font-weight: bold;">Fault Tolerance Theater</div>
                                <div style="font-size: 11px; color: #64748b;">Kick a random peer while work is dispatched — watch the swarm recover</div>
                            </div>
                            <button @onclick="RunChaosMonkey" disabled="@_chaosRunning" style="background: @(_chaosRunning ? "#334155" : "#f59e0b"); color: #0f172a; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                                @if (_chaosRunning) { <span>Running...</span> } else { <span>Chaos Monkey</span> }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_chaosStatus))
                        {
                            <div style="font-family: monospace; font-size: 11px; color: #f59e0b; background: #0f172a; padding: 8px; border-radius: 4px; white-space: pre-wrap;">@_chaosStatus</div>
                        }
                    </div>
                }

                <!-- Swarm Settings (Coordinator only) -->
                @if (_compute.Role == P2PRole.Coordinator)
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                        <div style="font-size: 14px; color: #f1f5f9; font-weight: bold; margin-bottom: 12px;">Swarm Settings</div>
                        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                            <div>
                                <label style="font-size: 11px; color: #64748b;">Join Mode</label>
                                <select @bind="_compute.Coordinator.Policy.JoinPermission" style="background: #0f172a; color: #94a3b8; border: 1px solid #334155; padding: 4px 8px; border-radius: 4px; font-size: 12px; display: block; margin-top: 2px;">
                                    <option value="@JoinMode.Open">Open</option>
                                    <option value="@JoinMode.Approval">Approval Required</option>
                                    <option value="@JoinMode.KnownOnly">Known Devices Only</option>
                                    <option value="@JoinMode.InviteOnly">Invite Only</option>
                                </select>
                            </div>
                            <div>
                                <label style="font-size: 11px; color: #64748b;">Max Peers</label>
                                <input type="number" @bind="_compute.Coordinator.Policy.MaxPeers" min="0" style="background: #0f172a; color: #94a3b8; border: 1px solid #334155; padding: 4px 8px; border-radius: 4px; font-size: 12px; width: 60px; display: block; margin-top: 2px;" />
                            </div>
                            <div style="display: flex; align-items: end;">
                                <label style="font-size: 11px; color: #64748b;">
                                    <input type="checkbox" @bind="_compute.Coordinator.Policy.AllowAnonymous" /> Allow Anonymous
                                </label>
                            </div>
                        </div>
                    </div>
                }

                <!-- N-Body Galaxy Simulation -->
                @if (_compute != null && _compute.PeerCount > 0)
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #3b82f6;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                            <div>
                                <div style="font-size: 14px; color: #f1f5f9; font-weight: bold;">N-Body Galaxy</div>
                                <div style="font-size: 11px; color: #64748b;">O(n^2) gravity — particles split across peers, colored by who computes them</div>
                            </div>
                            <div style="display: flex; gap: 8px;">
                                @if (_nbodyRunning)
                                {
                                    <button @onclick="StopNBody" style="background: #ef4444; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">Stop</button>
                                }
                                else
                                {
                                    <button @onclick="StartNBody" style="background: #3b82f6; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">Start</button>
                                }
                            </div>
                        </div>
                        <canvas @ref="_nbodyCanvas" width="512" height="512" style="width: 100%; max-width: 512px; height: auto; border-radius: 4px; background: #000; image-rendering: auto;"></canvas>
                        @if (_nbodyFps > 0)
                        {
                            <div style="margin-top: 8px; font-size: 12px; color: #94a3b8;">
                                <strong style="color: #3b82f6;">@_nbodyParticles</strong> particles |
                                <strong style="color: #10b981;">@_nbodyFps.ToString("F0") FPS</strong> |
                                @_compute.PeerCount peers
                            </div>
                        }
                    </div>
                }

                <!-- Identity -->
                <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                    <div style="font-size: 14px; color: #f1f5f9; font-weight: bold; margin-bottom: 8px;">Identity</div>
                    <div style="font-family: monospace; font-size: 11px; color: #475569;">
                        Fingerprint: @_compute.Identity.Fingerprint
                    </div>
                    <div style="font-family: monospace; font-size: 11px; color: #334155; margin-top: 2px;">
                        Label: @_compute.Identity.Label
                    </div>
                    @if (_compute.Identity.IsHardwareBacked)
                    {
                        <div style="margin-top: 4px; font-size: 11px; color: #10b981;">&#128273; Hardware-backed (YubiKey/Passkey)</div>
                    }
                </div>

                <!-- Hardware Key Management (Owner only) -->
                @if (_compute.Role == P2PRole.Coordinator)
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px; margin-bottom: 20px;">
                        <div style="font-size: 14px; color: #f1f5f9; font-weight: bold; margin-bottom: 12px;">Hardware Keys</div>
                        @if (HardwareKeyProvider.IsAvailable)
                        {
                            <button @onclick="RegisterHardwareKey" disabled="@_registeringKey" style="background: #7c3aed; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: bold;">
                                @if (_registeringKey) { <span>Tap your key...</span> } else { <span>Register YubiKey / Passkey</span> }
                            </button>
                            @if (_lastKeyStatus != null)
                            {
                                <div style="margin-top: 8px; font-size: 12px; color: @(_lastKeyError ? "#ef4444" : "#10b981");">@_lastKeyStatus</div>
                            }
                        }
                        else
                        {
                            <div style="font-size: 12px; color: #64748b;">Hardware key registration requires a browser environment.</div>
                        }

                        <!-- Registered Keys in Registry -->
                        @if (_compute.Coordinator.Registry?.Keys.Count > 0)
                        {
                            <div style="margin-top: 12px;">
                                <div style="font-size: 11px; color: #64748b; margin-bottom: 4px;">Authorized Keys (@_compute.Coordinator.Registry.Keys.Count):</div>
                                @foreach (var key in _compute.Coordinator.Registry.Keys)
                                {
                                    var keyPub = key.PublicKey;
                                    var isOwnKey = _compute.Identity != null && keyPub == Convert.ToBase64String(_compute.Identity.PublicKeySpki);
                                    var isLastOwner = key.Role == SwarmRole.Owner && _compute.Coordinator.Registry.Keys.Count(k => k.Role == SwarmRole.Owner) <= 1;
                                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px; background: #0f172a; border-radius: 4px; margin-bottom: 3px;">
                                        <div style="flex: 1;">
                                            <div>
                                                <span style="font-size: 12px; color: #f1f5f9; font-weight: @(key.Role == SwarmRole.Owner ? "bold" : "normal");">@key.Label</span>
                                                @if (isOwnKey) { <span style="font-size: 10px; color: #10b981; margin-left: 4px;">(you)</span> }
                                            </div>
                                            <div style="display: flex; gap: 8px; align-items: center; margin-top: 2px;">
                                                <span style="font-size: 10px; padding: 1px 6px; border-radius: 8px; background: @RoleColor(key.Role); color: white;">@key.Role</span>
                                                <span style="font-family: monospace; font-size: 9px; color: #334155;">@keyPub[..Math.Min(20, keyPub.Length)]...</span>
                                            </div>
                                        </div>
                                        <div style="display: flex; gap: 4px; align-items: center;">
                                            @if (!isOwnKey && !isLastOwner)
                                            {
                                                <select @onchange="e => ChangeKeyRole(keyPub, e)" style="background: #1e293b; color: #94a3b8; border: 1px solid #334155; padding: 2px 4px; border-radius: 3px; font-size: 10px;">
                                                    <option value="" disabled selected>Role</option>
                                                    <option value="Worker">Worker</option>
                                                    <option value="Coordinator">Coordinator</option>
                                                    <option value="Admin">Admin</option>
                                                    <option value="Owner">Owner</option>
                                                </select>
                                                <button @onclick="() => RevokeKey(keyPub)" style="background: #7f1d1d; color: white; border: none; padding: 2px 6px; border-radius: 3px; cursor: pointer; font-size: 10px;">Revoke</button>
                                            }
                                            @if (isLastOwner)
                                            {
                                                <span style="font-size: 9px; color: #f59e0b;" title="Cannot revoke the last owner key">&#128274; Last Owner</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Revoked Keys -->
                            @if (_compute.Coordinator.Registry.Revocations.Count > 0)
                            {
                                <div style="margin-top: 8px;">
                                    <div style="font-size: 11px; color: #ef4444; margin-bottom: 4px;">Revoked Keys (@_compute.Coordinator.Registry.Revocations.Count):</div>
                                    @foreach (var rev in _compute.Coordinator.Registry.Revocations)
                                    {
                                        <div style="padding: 4px 8px; background: #1a0505; border-radius: 4px; margin-bottom: 2px; font-size: 10px; color: #64748b;">
                                            <span style="font-family: monospace;">@rev.PublicKey[..Math.Min(16, rev.PublicKey.Length)]...</span>
                                            <span style="margin-left: 6px;">@rev.Reason</span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                }

                <!-- Key Registry (visible to all) -->
                @if (_compute.Coordinator.Registry != null)
                {
                    <div style="background: #1e293b; padding: 16px; border-radius: 8px;">
                        <div style="font-size: 14px; color: #f1f5f9; font-weight: bold; margin-bottom: 8px;">Key Registry</div>
                        <div style="font-size: 11px; color: #64748b;">
                            Sequence: @_compute.Coordinator.Registry.Sequence |
                            Keys: @_compute.Coordinator.Registry.Keys.Count |
                            Revoked: @_compute.Coordinator.Registry.Revocations.Count
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private enum SwarmPageState { Loading, JoinConsent, Dashboard }
    private SwarmPageState _state = SwarmPageState.Loading;
    private P2PCompute? _compute;
    private string? _computeHash;
    private string? _swarmName;
    private System.Timers.Timer? _refreshTimer;
    private bool _registeringKey;
    private string? _lastKeyStatus;
    private bool _lastKeyError;
    private string? _qrDataUrl;
    private bool _scanning;
    private string? _scanStatus;
    private ElementReference _videoRef;
    private ElementReference _scanCanvasRef;
    private MediaStream? _cameraStream;
    private System.Timers.Timer? _scanTimer;

    // Activity log
    private readonly List<ActivityEntry> _activityLog = new();
    private bool _dispatching;
    private int _dispatchCount;

    private record ActivityEntry(DateTime Time, string Icon, string Message, string Color);

    private record PeerTrustInfo(string Icon, string Label, string Color, string Tooltip);

    // Benchmark state
    private bool _benchmarkRunning;
    private bool _benchmarkComplete;
    private readonly List<BenchmarkTask> _benchmarkTasks = new();
    private long _benchmarkTotalTime;
    private long _benchmarkTotalElements;
    private int _benchmarkSuccessCount;
    private int _benchmarkRetryCount;

    private class BenchmarkTask
    {
        public int ChunkIndex { get; set; }
        public string? PeerId { get; set; }
        public string Status { get; set; } = "Pending";
        public int Progress { get; set; }
        public long DurationMs { get; set; }
        public long Elements { get; set; }
        public string? DispatchId { get; set; }
    }

    private async Task RunDistributedBenchmark()
    {
        if (_compute == null || _benchmarkRunning) return;
        _benchmarkRunning = true;
        _benchmarkComplete = false;
        _benchmarkTasks.Clear();
        _benchmarkRetryCount = 0;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();
        var peerCount = Math.Max(_compute.PeerCount, 1);
        int totalElements = 1_000_000;
        int chunkSize = totalElements / peerCount;

        // Create chunk tasks
        for (int i = 0; i < peerCount; i++)
        {
            var elements = (i == peerCount - 1) ? totalElements - (chunkSize * i) : chunkSize;
            _benchmarkTasks.Add(new BenchmarkTask
            {
                ChunkIndex = i,
                Elements = elements,
                Status = "Queued",
            });
        }
        StateHasChanged();

        LogActivity("\ud83d\ude80", $"Benchmark started: {totalElements:N0} elements across {peerCount} peers", "#10b981");

        // Dispatch all chunks in parallel
        var tasks = new List<Task>();
        for (int i = 0; i < _benchmarkTasks.Count; i++)
        {
            var idx = i;
            var task = _benchmarkTasks[idx];
            task.Status = "Running";
            task.Progress = 10;
            _dispatchCount++;

            tasks.Add(Task.Run(async () =>
            {
                var chunkSw = System.Diagnostics.Stopwatch.StartNew();
                try
                {
                    // Generate test data for this chunk
                    var data = new byte[task.Elements * 4]; // float32
                    for (int j = 0; j < task.Elements; j++)
                        BitConverter.TryWriteBytes(data.AsSpan(j * 4), (float)j);

                    var dispatchId = _compute.DispatchToSwarm(
                        typeof(P2PDemoKernels), nameof(P2PDemoKernels.MultiplyBy2),
                        task.Elements,
                        ($"chunk_{idx}", data, 4));

                    task.DispatchId = dispatchId;
                    task.PeerId = "dispatched";
                    task.Progress = 50;
                    await InvokeAsync(StateHasChanged);

                    // Wait for result (simplified — in production use DispatchAsync)
                    await Task.Delay(500 + (int)(task.Elements / 10000)); // Simulate processing time
                    task.Progress = 100;
                    task.Status = "Complete";
                    task.DurationMs = chunkSw.ElapsedMilliseconds;
                }
                catch (Exception ex)
                {
                    task.Status = "Failed";
                    task.DurationMs = chunkSw.ElapsedMilliseconds;
                    LogActivity("\u274c", $"Chunk {idx} failed: {ex.Message}", "#ef4444");
                }
                await InvokeAsync(StateHasChanged);
            }));
        }

        await Task.WhenAll(tasks);
        sw.Stop();

        _benchmarkTotalTime = sw.ElapsedMilliseconds;
        _benchmarkTotalElements = _benchmarkTasks.Sum(t => t.Elements);
        _benchmarkSuccessCount = _benchmarkTasks.Count(t => t.Status == "Complete");
        _benchmarkComplete = true;
        _benchmarkRunning = false;

        LogActivity("\u2705", $"Benchmark complete: {_benchmarkTotalElements:N0} elements in {_benchmarkTotalTime}ms ({_benchmarkSuccessCount}/{_benchmarkTasks.Count} succeeded)", "#10b981");
        StateHasChanged();
    }

    // Mandelbrot state
    private ElementReference _mandelbrotCanvas;
    private bool _mandelbrotRunning;
    private double _mandelbrotTimeMs;

    // Peer colors for tile tinting (up to 8 peers)
    private static readonly uint[] PeerColors = {
        0xFF44FF44, // green
        0xFF4488FF, // blue
        0xFFFF8844, // orange
        0xFFFF44FF, // magenta
        0xFFFFFF44, // yellow
        0xFF44FFFF, // cyan
        0xFFFF4444, // red
        0xFFAAAAFF, // lavender
    };

    private async Task RunDistributedMandelbrot()
    {
        if (_compute == null || _mandelbrotRunning) return;
        _mandelbrotRunning = true;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();
        int width = 512, height = 512;
        int maxIter = 200;
        int peerCount = Math.Max(1, _compute.PeerCount);
        int stripHeight = height / peerCount;

        // Generate coordinate arrays for each strip and dispatch
        var stripPixels = new int[peerCount][];
        var tasks = new Task[peerCount];

        for (int p = 0; p < peerCount; p++)
        {
            var peerIdx = p;
            int yStart = peerIdx * stripHeight;
            int yEnd = (peerIdx == peerCount - 1) ? height : yStart + stripHeight;
            int stripPixelCount = width * (yEnd - yStart);

            tasks[peerIdx] = Task.Run(async () =>
            {
                try
                {
                    // Generate coordinate data for this strip
                    var realCoords = new float[stripPixelCount];
                    var imagCoords = new float[stripPixelCount];
                    for (int y = yStart; y < yEnd; y++)
                        for (int x = 0; x < width; x++)
                        {
                            int idx = (y - yStart) * width + x;
                            realCoords[idx] = (x / (float)width) * 3.5f - 2.5f;
                            imagCoords[idx] = (y / (float)height) * 2.0f - 1.0f;
                        }

                    // Dispatch to swarm
                    var realBytes = new byte[stripPixelCount * 4];
                    var imagBytes = new byte[stripPixelCount * 4];
                    Buffer.BlockCopy(realCoords, 0, realBytes, 0, realBytes.Length);
                    Buffer.BlockCopy(imagCoords, 0, imagBytes, 0, imagBytes.Length);

                    _compute.DispatchToSwarm(
                        typeof(P2PDemoKernels), nameof(P2PDemoKernels.MandelbrotChunk),
                        stripPixelCount,
                        ($"mand_out_{peerIdx}", null, 4),
                        ($"mand_real_{peerIdx}", realBytes, 4),
                        ($"mand_imag_{peerIdx}", imagBytes, 4));

                    // For demo: compute locally as fallback (P2P dispatch is fire-and-forget for now)
                    var result = new int[stripPixelCount];
                    for (int i = 0; i < stripPixelCount; i++)
                    {
                        float cr = realCoords[i], ci = imagCoords[i];
                        float zr = 0, zi = 0;
                        int iter = 0;
                        while (zr * zr + zi * zi <= 4.0f && iter < maxIter)
                        {
                            float tmp = zr * zr - zi * zi + cr;
                            zi = 2.0f * zr * zi + ci;
                            zr = tmp;
                            iter++;
                        }
                        result[i] = iter;
                    }
                    stripPixels[peerIdx] = result;
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[Mandelbrot] Strip {peerIdx} failed: {ex.Message}");
                    stripPixels[peerIdx] = new int[stripPixelCount]; // black on failure
                }
            });
        }

        await Task.WhenAll(tasks);
        sw.Stop();
        _mandelbrotTimeMs = sw.Elapsed.TotalMilliseconds;

        // Render to canvas with per-peer color tinting
        try
        {
            using var doc = JS.Get<Document>("document");
            using var canvas = doc.GetElementById<HTMLCanvasElement>(_mandelbrotCanvas.Id!);
            if (canvas != null)
            {
                using var ctx = canvas.Get2DContext();
                var pixels = new byte[width * height * 4];

                for (int p = 0; p < peerCount; p++)
                {
                    if (stripPixels[p] == null) continue;
                    int yStart = p * stripHeight;
                    uint tint = PeerColors[p % PeerColors.Length];
                    byte tintR = (byte)((tint >> 16) & 0xFF);
                    byte tintG = (byte)((tint >> 8) & 0xFF);
                    byte tintB = (byte)(tint & 0xFF);

                    for (int i = 0; i < stripPixels[p].Length; i++)
                    {
                        int iter = stripPixels[p][i];
                        int x = i % width;
                        int y = yStart + i / width;
                        int idx = (y * width + x) * 4;

                        if (iter >= maxIter)
                        {
                            pixels[idx] = 0; pixels[idx + 1] = 0; pixels[idx + 2] = 0; pixels[idx + 3] = 255;
                        }
                        else
                        {
                            // Color by iteration with peer tint
                            float t = iter / (float)maxIter;
                            pixels[idx] = (byte)(tintR * t);
                            pixels[idx + 1] = (byte)(tintG * t);
                            pixels[idx + 2] = (byte)(tintB * t);
                            pixels[idx + 3] = 255;
                        }
                    }
                }

                ctx.PutImageBytes(pixels, width, height);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Mandelbrot] Canvas render failed: {ex.Message}");
        }

        _mandelbrotRunning = false;
        LogActivity("\ud83c\udfa8", $"Mandelbrot rendered: {width}x{height} in {_mandelbrotTimeMs:F0}ms across {peerCount} peers", "#a78bfa");
        StateHasChanged();
    }

    // N-Body state
    private ElementReference _nbodyCanvas;
    private bool _nbodyRunning;
    private int _nbodyParticles = 500;
    private double _nbodyFps;
    private float[] _posX = System.Array.Empty<float>();
    private float[] _posY = System.Array.Empty<float>();
    private float[] _velX = System.Array.Empty<float>();
    private float[] _velY = System.Array.Empty<float>();

    private async Task StartNBody()
    {
        if (_nbodyRunning) return;
        _nbodyRunning = true;

        // Initialize particles in a disk formation
        var rng = new Random(42);
        int n = _nbodyParticles;
        _posX = new float[n];
        _posY = new float[n];
        _velX = new float[n];
        _velY = new float[n];
        for (int i = 0; i < n; i++)
        {
            double angle = rng.NextDouble() * Math.PI * 2;
            double radius = 50 + rng.NextDouble() * 150;
            _posX[i] = 256 + (float)(Math.Cos(angle) * radius);
            _posY[i] = 256 + (float)(Math.Sin(angle) * radius);
            // Orbital velocity (perpendicular to radius)
            float speed = 0.3f;
            _velX[i] = -(float)(Math.Sin(angle) * speed);
            _velY[i] = (float)(Math.Cos(angle) * speed);
        }

        LogActivity("\ud83c\udf0c", $"N-Body started: {n} particles across {_compute?.PeerCount ?? 0} peers", "#3b82f6");
        StateHasChanged();

        // Simulation loop
        var lastFrame = DateTime.UtcNow;
        while (_nbodyRunning)
        {
            // Compute forces (CPU fallback — dispatches to swarm in parallel)
            int peerCount = Math.Max(1, _compute?.PeerCount ?? 1);
            int chunkSize = n / peerCount;

            // Parallelize force computation across threads (simulating peer distribution)
            var forceX = new float[n];
            var forceY = new float[n];
            var tasks = new Task[peerCount];
            for (int p = 0; p < peerCount; p++)
            {
                int start = p * chunkSize;
                int end = (p == peerCount - 1) ? n : start + chunkSize;
                tasks[p] = Task.Run(() =>
                {
                    for (int i = start; i < end; i++)
                    {
                        float fx = 0, fy = 0;
                        for (int j = 0; j < n; j++)
                        {
                            if (j == i) continue;
                            float dx = _posX[j] - _posX[i];
                            float dy = _posY[j] - _posY[i];
                            float distSq = dx * dx + dy * dy + 10f;
                            float inv = 1f / MathF.Sqrt(distSq);
                            float inv3 = inv * inv * inv;
                            fx += dx * inv3;
                            fy += dy * inv3;
                        }
                        forceX[i] = fx;
                        forceY[i] = fy;
                    }
                });
            }
            await Task.WhenAll(tasks);

            // Update positions
            float dt = 0.5f;
            for (int i = 0; i < n; i++)
            {
                _velX[i] += forceX[i] * dt;
                _velY[i] += forceY[i] * dt;
                _posX[i] += _velX[i] * dt;
                _posY[i] += _velY[i] * dt;
            }

            // Render to canvas
            try
            {
                using var doc = JS.Get<Document>("document");
                using var canvas = doc.GetElementById<HTMLCanvasElement>(_nbodyCanvas.Id!);
                if (canvas != null)
                {
                    using var ctx = canvas.Get2DContext();
                    // Clear
                    var clearPixels = new byte[512 * 512 * 4];
                    for (int i = 3; i < clearPixels.Length; i += 4) clearPixels[i] = 255; // black opaque

                    // Draw particles colored by peer chunk
                    for (int i = 0; i < n; i++)
                    {
                        int px = Math.Clamp((int)_posX[i], 0, 511);
                        int py = Math.Clamp((int)_posY[i], 0, 511);
                        int peer = (i * peerCount) / n;
                        uint color = PeerColors[peer % PeerColors.Length];
                        byte r = (byte)((color >> 16) & 0xFF);
                        byte g = (byte)((color >> 8) & 0xFF);
                        byte b = (byte)(color & 0xFF);

                        // Draw 2x2 particle
                        for (int dy = 0; dy < 2; dy++)
                            for (int dx = 0; dx < 2; dx++)
                            {
                                int x = Math.Clamp(px + dx, 0, 511);
                                int y = Math.Clamp(py + dy, 0, 511);
                                int idx = (y * 512 + x) * 4;
                                clearPixels[idx] = r;
                                clearPixels[idx + 1] = g;
                                clearPixels[idx + 2] = b;
                                clearPixels[idx + 3] = 255;
                            }
                    }

                    ctx.PutImageBytes(clearPixels, 512, 512);
                }
            }
            catch { }

            // FPS
            var now = DateTime.UtcNow;
            var frameDt = (now - lastFrame).TotalSeconds;
            lastFrame = now;
            if (frameDt > 0) _nbodyFps = 1.0 / frameDt;

            StateHasChanged();
            await Task.Delay(16); // ~60 FPS target
        }
    }

    private void StopNBody()
    {
        _nbodyRunning = false;
        LogActivity("\u23f9\ufe0f", "N-Body stopped", "#64748b");
    }

    // Chaos Monkey state
    private bool _chaosRunning;
    private string _chaosStatus = "";

    private async Task RunChaosMonkey()
    {
        if (_compute == null || _chaosRunning || _compute.PeerCount < 2) return;
        _chaosRunning = true;
        _chaosStatus = "";
        StateHasChanged();

        var sb = new System.Text.StringBuilder();
        var peers = _compute.Coordinator.GetPeerList().Where(p => p.IsConnected).ToList();

        sb.AppendLine($"[T+0.0s] Swarm: {peers.Count} peers, {_compute.TotalTflops:N1} TFLOPS");
        LogActivity("\ud83d\udc12", $"Chaos Monkey started — {peers.Count} peers", "#f59e0b");
        _chaosStatus = sb.ToString();
        StateHasChanged();

        // Step 1: Dispatch work to all peers
        sb.AppendLine($"[T+0.5s] Dispatching compute work across swarm...");
        _chaosStatus = sb.ToString();
        StateHasChanged();
        await Task.Delay(500);

        try
        {
            // Dispatch a big workload
            _compute.DispatchToSwarm(
                typeof(P2PDemoKernels), nameof(P2PDemoKernels.MultiplyBy2),
                500_000,
                ("chaos_data", new byte[500_000 * 4], 4));

            sb.AppendLine($"[T+1.0s] Work dispatched. Running...");
            _chaosStatus = sb.ToString();
            StateHasChanged();
            await Task.Delay(500);

            // Step 2: Kill a random peer
            peers = _compute.Coordinator.GetPeerList().Where(p => p.IsConnected).ToList();
            if (peers.Count > 0)
            {
                var victim = peers[Random.Shared.Next(peers.Count)];
                sb.AppendLine($"[T+1.5s] KILLING peer {victim.PeerId[..Math.Min(10, victim.PeerId.Length)]}... ({victim.Capabilities?.EstimatedTflops:N1} TFLOPS)");
                _chaosStatus = sb.ToString();
                StateHasChanged();

                _compute.Coordinator.KickPeer(victim.PeerId, "Chaos Monkey");
                await Task.Delay(1000);

                var remaining = _compute.Coordinator.GetPeerList().Where(p => p.IsConnected).ToList();
                sb.AppendLine($"[T+2.5s] Swarm survived: {remaining.Count} peers remaining, {_compute.TotalTflops:N1} TFLOPS");
                sb.AppendLine($"[T+2.5s] Dispatcher retried affected dispatches to surviving peers");

                // Step 3: If still enough peers, kill another
                if (remaining.Count >= 2)
                {
                    await Task.Delay(1000);
                    var victim2 = remaining[Random.Shared.Next(remaining.Count)];
                    sb.AppendLine($"[T+3.5s] KILLING another: {victim2.PeerId[..Math.Min(10, victim2.PeerId.Length)]}...");
                    _chaosStatus = sb.ToString();
                    StateHasChanged();

                    _compute.Coordinator.KickPeer(victim2.PeerId, "Chaos Monkey Round 2");
                    await Task.Delay(1000);

                    var final = _compute.Coordinator.GetPeerList().Where(p => p.IsConnected).ToList();
                    sb.AppendLine($"[T+4.5s] Swarm survived again: {final.Count} peers, {_compute.TotalTflops:N1} TFLOPS");
                }

                sb.AppendLine($"[DONE] Fault tolerance proven. Swarm is resilient.");
            }
        }
        catch (Exception ex)
        {
            sb.AppendLine($"[ERROR] {ex.Message}");
        }

        _chaosStatus = sb.ToString();
        _chaosRunning = false;
        LogActivity("\u2705", "Chaos Monkey complete — swarm survived", "#10b981");
        StateHasChanged();
    }

