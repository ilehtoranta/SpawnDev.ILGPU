    private async Task RegisterHardwareKey()
    {
        if (_compute == null) return;
        _registeringKey = true;
        _lastKeyStatus = null;
        _lastKeyError = false;
        StateHasChanged();

        try
        {
            var provider = new HardwareKeyProvider();
            var credential = await provider.RegisterAsync("Owner Key " + DateTime.Now.ToString("MMdd-HHmm"));

            if (credential == null)
            {
                _lastKeyStatus = "Registration cancelled.";
                _lastKeyError = true;
            }
            else
            {
                // Create hardware-backed identity
                var hwIdentity = await SwarmIdentity.FromHardwareKeyAsync(Crypto, credential);

                // Add to registry as Owner
                if (_compute.Coordinator.Registry == null)
                    throw new InvalidOperationException("KeyRegistry not initialized — create a swarm first");
                _compute.Coordinator.Registry.AddKey(
                    hwIdentity.PublicKeySpki, SwarmRole.Owner, credential.Label);

                // Sign the updated registry
                if (_compute.Identity != null)
                    await _compute.Coordinator.Registry.SignAsync(_compute.Identity);

                _lastKeyStatus = $"Registered: {credential.Label} ({string.Join(", ", credential.Transports)})";
                _lastKeyError = false;

                await hwIdentity.DisposeAsync();
            }
        }
        catch (Exception ex)
        {
            _lastKeyStatus = $"Error: {ex.Message}";
            _lastKeyError = true;
        }

        _registeringKey = false;
        StateHasChanged();
    }

    private async Task StartScanning()
    {
        try
        {
            using var mediaDevices = JS.Get<MediaDevices>("navigator.mediaDevices");
            _cameraStream = await mediaDevices.GetUserMedia(new { video = new { facingMode = "environment" } , audio = false });
            if (_cameraStream == null) return;

            _scanning = true;
            StateHasChanged();

            // Wait for Blazor to render the video element
            await Task.Delay(100);

            // Attach stream to video element
            using var doc = JS.Get<Document>("document");
            using var video = doc.GetElementById<HTMLVideoElement>(_videoRef.Id!);
            if (video != null)
            {
                video.SrcObject = _cameraStream;
            }

            // Start scanning timer
            _scanTimer = new System.Timers.Timer(500); // scan every 500ms
            _scanTimer.Elapsed += async (s, e) => await ScanFrame();
            _scanTimer.Start();
        }
        catch (Exception ex)
        {
            _scanStatus = $"Camera error: {ex.Message}";
            _scanning = false;
            StateHasChanged();
        }
    }

    private async Task StopScanning()
    {
        _scanTimer?.Stop();
        _scanTimer?.Dispose();
        _scanTimer = null;

        if (_cameraStream != null)
        {
            using var tracks = _cameraStream.GetTracks();
            for (int i = 0; i < tracks.Length; i++)
            {
                using var track = tracks[i];
                track.Stop();
            }
            _cameraStream.Dispose();
            _cameraStream = null;
        }

        _scanning = false;
        _scanStatus = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ScanFrame()
    {
        try
        {
            if (!_scanning || _scanCanvasRef.Id == null) return;

            using var doc = JS.Get<Document>("document");
            using var canvas = doc.GetElementById<HTMLCanvasElement>(_scanCanvasRef.Id!);
            if (canvas == null) return;

            using var ctx = canvas.Get2DContext();
            using var video = doc.GetElementById<HTMLVideoElement>(_videoRef.Id!);
            if (video == null || video.VideoWidth == 0) return;

            int w = 240, h = 240;
            ctx.DrawImage(video, 0, 0, w, h);
            var pixels = ctx.GetImageBytes(0, 0, w, h);
            if (pixels == null || pixels.Length == 0) return;

            var decoded = QRDecoder.Decode(pixels, w, h);
            if (decoded != null && decoded.StartsWith("http"))
            {
                await InvokeAsync(async () =>
                {
                    _scanStatus = $"Found: {decoded}";
                    StateHasChanged();
                    await StopScanning();

                    // Parse and join
                    var (hash, name) = P2PCompute.ParseJoinLink(decoded);
                    if (hash != null)
                    {
                        _computeHash = hash;
                        _swarmName = name ?? "Scanned Swarm";
                        _state = SwarmPageState.JoinConsent;
                        StateHasChanged();
                    }
                });
            }
        }
        catch { }
    }

    private async Task GenerateQRCode()
    {
        var link = _compute?.JoinLink ?? _compute?.MagnetLink;
        if (string.IsNullOrEmpty(link)) return;

        try
        {
            // Generate QR code pixels (CPU — fast for small images)
            var (pixels, w, h) = QRCode.Generate(link, QRTables.ECLevel.H, moduleSize: 6, quietZone: 2);

            // QR renderer outputs ARGB (uint layout), canvas needs RGBA byte order
            // On little-endian (which WASM is), uint ARGB = bytes [B, G, R, A]
            // Canvas ImageData expects [R, G, B, A]
            // Swap R and B channels
            for (int i = 0; i < pixels.Length; i += 4)
            {
                (pixels[i], pixels[i + 2]) = (pixels[i + 2], pixels[i]); // swap B↔R
            }

            // Render to offscreen canvas → data URL
            using var canvas = new OffscreenCanvas(w, h);
            using var ctx = canvas.Get2DContext();
            ctx.PutImageBytes(pixels, w, h);
            using var blob = await canvas.ConvertToBlob();
            _qrDataUrl = await blob.ToDataURLAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[QR] Error generating QR code: {ex.Message}");
        }
    }

    private async Task CopyJoinLink()
    {
        if (_compute?.JoinLink != null)
        {
            try { JS.CallVoid("navigator.clipboard.writeText", _compute.JoinLink); }
            catch { }
        }
    }

    private async Task ChangeKeyRole(string publicKey, ChangeEventArgs e)
    {
        if (_compute?.Coordinator.Registry == null || e.Value == null) return;
        var roleName = e.Value.ToString();
        if (string.IsNullOrEmpty(roleName)) return;

        var newRole = Enum.Parse<SwarmRole>(roleName);
        var key = _compute.Coordinator.Registry.Keys.FirstOrDefault(k => k.PublicKey == publicKey);
        if (key != null)
        {
            key.Role = newRole;
            if (_compute.Identity != null)
                await _compute.Coordinator.Registry.SignAsync(_compute.Identity);
            StateHasChanged();
        }
    }

    private async Task RevokeKey(string publicKey)
    {
        if (_compute?.Coordinator.Registry == null) return;
        _compute.Coordinator.Registry.RevokeKey(Convert.FromBase64String(publicKey), "Revoked by coordinator");
        if (_compute.Identity != null)
            await _compute.Coordinator.Registry.SignAsync(_compute.Identity);
        StateHasChanged();
    }

    private static string RoleColor(SwarmRole role) => role switch
    {
        SwarmRole.Owner => "#7c3aed",
        SwarmRole.Admin => "#3b82f6",
        SwarmRole.Coordinator => "#10b981",
        SwarmRole.Worker => "#64748b",
        _ => "#334155",
    };

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024 * 1024):N1} GB";
        if (bytes >= 1024L * 1024) return $"{bytes / (1024.0 * 1024):N0} MB";
        return $"{bytes / 1024.0:N0} KB";
    }

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Dispose();
        if (_compute != null) await _compute.DisposeAsync();
    }
}
