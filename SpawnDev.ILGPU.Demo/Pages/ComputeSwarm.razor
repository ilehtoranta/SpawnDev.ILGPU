    private PeerTrustInfo GetPeerTrust(RemotePeer peer)
    {
        var caps = peer.Capabilities;
        if (caps == null)
            return new("?", "Unknown", "#64748b", "No capabilities received");

        var fingerprint = caps.Fingerprint ?? "";
        var pubKey = caps.PublicKey ?? "";
        var registry = _compute?.Coordinator.Registry;

        // Check if peer's key is in the registry
        bool isRegistered = registry != null && !string.IsNullOrEmpty(pubKey)
            && registry.HasRole(pubKey, SwarmRole.Worker);
        bool isRevoked = registry != null && !string.IsNullOrEmpty(pubKey)
            && registry.IsRevoked(pubKey);

        if (isRevoked)
            return new("\u26d4", "Revoked", "#ef4444", "Key revoked — untrusted");

        if (isRegistered)
        {
            var role = registry!.Keys.FirstOrDefault(k => k.PublicKey == pubKey)?.Role ?? SwarmRole.Worker;
            return role switch
            {
                SwarmRole.Owner => new("\ud83d\udd12", "Owner", "#7c3aed", "Hardware-backed owner key in registry"),
                SwarmRole.Admin => new("\u2705", "Admin", "#3b82f6", "Admin key verified in registry"),
                SwarmRole.Coordinator => new("\u2705", "Coord", "#10b981", "Coordinator key verified in registry"),
                _ => new("\u2705", "Verified", "#10b981", "Key verified in swarm registry"),
            };
        }

        if (!string.IsNullOrEmpty(fingerprint))
            return new("\ud83d\udd11", "Identified", "#f59e0b", $"ECDSA identity: {fingerprint[..Math.Min(12, fingerprint.Length)]}...");

        return new("\ud83d\udc64", "Anonymous", "#64748b", "No cryptographic identity provided");
    }

    private long GetTotalMemory()
    {
        if (_compute == null) return 0;
        return _compute.Coordinator.GetPeerList().Sum(p => p.Capabilities?.AvailableMemory ?? 0);
    }

    private int GetVerifiedCount()
    {
        if (_compute == null) return 0;
        return _compute.Coordinator.GetPeerList().Count(p =>
        {
            var trust = GetPeerTrust(p);
            return trust.Label != "Anonymous" && trust.Label != "Unknown";
        });
    }

    private string GetVerifiedColor()
    {
        if (_compute == null || _compute.PeerCount == 0) return "#334155";
        var verified = GetVerifiedCount();
        if (verified == _compute.PeerCount) return "#10b981";
        if (verified > 0) return "#f59e0b";
        return "#ef4444";
    }

    protected override async Task OnInitializedAsync()
    {
        // Check if this is a join link (URL takes priority over saved state)
        var (hash, name) = P2PCompute.ParseJoinLink(Nav.Uri);

        // If no URL join link, try to restore from saved swarm state
        if (hash == null)
        {
            try
            {
                var savedMagnet = JS.Call<string>("localStorage.getItem", "p2p-swarm-magnet");
                var savedRole = JS.Call<string>("localStorage.getItem", "p2p-swarm-role");
                if (!string.IsNullOrEmpty(savedMagnet))
                {
                    _state = SwarmPageState.Dashboard;
                    LogActivity("\ud83d\udd04", "Restoring swarm from saved state...", "#f59e0b");
                    StateHasChanged();

                    if (savedRole == "coordinator")
                    {
                        await CreateSwarm();
                    }
                    else
                    {
                        var (savedHash, savedName) = P2PCompute.ParseJoinLink(savedMagnet);
                        if (savedHash != null)
                        {
                            _computeHash = savedHash;
                            _swarmName = savedName ?? "Restored Swarm";
                            await JoinSwarm();
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[P2P] Swarm restore failed: {ex.Message}");
            }
        }

        if (hash != null)
        {
            _computeHash = hash;
            _swarmName = name ?? "Unknown Swarm";

            // Auto-join if URL has autojoin=1 parameter or saved consent
            bool autoJoin = Nav.Uri.Contains("autojoin=1", StringComparison.OrdinalIgnoreCase);
            try
            {
                var consent = JS.Call<string>("localStorage.getItem", $"p2p-consent-{hash}");
                if (consent == "always") autoJoin = true;
            }
            catch { }

            if (autoJoin)
            {
                _state = SwarmPageState.Dashboard;
                await JoinSwarm();
            }
            else
            {
                _state = SwarmPageState.JoinConsent;
            }
        }
        else
        {
            _state = SwarmPageState.Dashboard;
        }

        // Start refresh timer for live updates (all paths need this)
        _refreshTimer = new System.Timers.Timer(2000);
        _refreshTimer.Elapsed += (s, e) => InvokeAsync(StateHasChanged);
        _refreshTimer.Start();
    }

    /// <summary>
    /// Get or create a persistent device identity.
    /// First visit: generate ECDSA key pair, store in localStorage.
    /// Subsequent visits: import from localStorage.
    /// </summary>
    private async Task<SwarmIdentity> GetOrCreateIdentityAsync()
    {
        var crypto = Crypto;

        try
        {
            // Try to load from localStorage
            var pubB64 = JS.Call<string>("localStorage.getItem", "p2p-identity-pub");
            var privB64 = JS.Call<string>("localStorage.getItem", "p2p-identity-priv");

            if (!string.IsNullOrEmpty(pubB64) && !string.IsNullOrEmpty(privB64))
            {
                var pub = Convert.FromBase64String(pubB64);
                var priv = Convert.FromBase64String(privB64);
                return await SwarmIdentity.ImportAsync(crypto, pub, priv);
            }
        }
        catch { }

        // Generate new identity
        var identity = await SwarmIdentity.CreateAsync(crypto, "Device-" + Guid.NewGuid().ToString("N")[..6]);

        // Persist to localStorage
        try
        {
            var priv = await identity.ExportPrivateKeyAsync();
            JS.CallVoid("localStorage.setItem", "p2p-identity-pub", Convert.ToBase64String(identity.PublicKeySpki));
            JS.CallVoid("localStorage.setItem", "p2p-identity-priv", Convert.ToBase64String(priv));
        }
        catch { }

        return identity;
    }

    private async Task CreateSwarm()
    {
        var client = WebTorrentClient;
        SpawnDev.WebTorrent.WebTorrentClient.VerboseLogging = true;
        Console.WriteLine($"[P2P CreateSwarm] PeerId: {Convert.ToHexString(client.PeerId)}");
        _compute = await P2PCompute.CreateSwarmAsync(Crypto, client, "Demo Compute Swarm");
        SwarmService.SetCompute(_compute);
        // Debug: verify tracker is in metadata
        var swarm = _compute.Coordinator.Swarm;
        var announceCount = swarm?.Metadata?.AnnounceList?.Length ?? -1;
        var trackerUrls = announceCount > 0
            ? string.Join(", ", swarm!.Metadata!.AnnounceList.SelectMany(t => t))
            : "NONE";
        JS.CallVoid("console.log", $"[P2P] Swarm created. Torrents: {client.Torrents.Count}, AnnounceList: [{trackerUrls}], IsBrowser: {OperatingSystem.IsBrowser()}");
        await GenerateQRCode();
        WireSwarmEvents();
        SaveSwarmState();
        LogActivity("\ud83d\ude80", "Swarm created — you are the coordinator", "#10b981");
        StateHasChanged();
    }

    private void WireSwarmEvents()
    {
        if (_compute == null) return;

        _compute.Coordinator.OnPeerJoined += (peer) =>
        {
            var trust = GetPeerTrust(peer);
            LogActivity("\u2795", $"Peer joined: {peer.PeerId[..Math.Min(10, peer.PeerId.Length)]}... ({peer.Capabilities?.EstimatedTflops:N1} TFLOPS) [{trust.Label}]", "#10b981");
        };
        _compute.Coordinator.OnPeerLeft += (peer) =>
        {
            LogActivity("\u274c", $"Peer left: {peer.PeerId[..Math.Min(10, peer.PeerId.Length)]}...", "#ef4444");
        };
        _compute.Coordinator.OnPeerKicked += (peerId, reason) =>
        {
            LogActivity("\ud83d\udeab", $"Peer kicked: {peerId[..Math.Min(10, peerId.Length)]}... — {reason}", "#f59e0b");
        };
        _compute.Coordinator.OnPeerBlocked += (peerId, reason) =>
        {
            LogActivity("\u26d4", $"Peer blocked: {peerId[..Math.Min(10, peerId.Length)]}... — {reason}", "#ef4444");
        };
        _compute.Coordinator.OnPeerRejected += (peerId, reason) =>
        {
            LogActivity("\u26a0\ufe0f", $"Peer rejected: {peerId[..Math.Min(10, peerId.Length)]}... — {reason}", "#f59e0b");
        };
        _compute.Coordinator.OnCapacityChanged += () =>
        {
            LogActivity("\ud83d\udcca", $"Capacity: {_compute.TotalTflops:N1} TFLOPS, {_compute.PeerCount} peers, {FormatBytes(GetTotalMemory())}", "#3b82f6");
        };
        _compute.Coordinator.OnCoordinatorChanged += (newCoordId) =>
        {
            if (newCoordId == null)
                LogActivity("\ud83d\udc51", "You are now the coordinator", "#7c3aed");
            else
                LogActivity("\ud83d\udc51", $"Coordinator changed to: {newCoordId[..Math.Min(10, newCoordId.Length)]}...", "#f59e0b");
        };

        if (_compute.Dispatcher != null)
        {
            _compute.Dispatcher.OnDispatchFailed += (id, reason) =>
            {
                LogActivity("\u274c", $"Dispatch {id[..Math.Min(8, id.Length)]}... failed: {reason}", "#ef4444");
            };
            _compute.Dispatcher.OnDispatchRetried += (id, failedPeerId, newPeerId) =>
            {
                LogActivity("\ud83d\udd04", $"Dispatch {id[..Math.Min(8, id.Length)]}... retried: {failedPeerId[..Math.Min(8, failedPeerId.Length)]}... → {newPeerId[..Math.Min(8, newPeerId.Length)]}...", "#f59e0b");
            };
        }
    }

