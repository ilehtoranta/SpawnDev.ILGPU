    private async Task JoinSwarm()
    {
        if (_computeHash == null) return;
        _state = SwarmPageState.Dashboard;

        // Create a real accelerator using the best available backend
        var builder = global::ILGPU.Context.Create();
        await builder.AllAcceleratorsAsync();
        var context = builder.ToContext();
        var accelerator = await context.CreatePreferredAcceleratorAsync();

        var client = WebTorrentClient;
        SpawnDev.WebTorrent.WebTorrentClient.VerboseLogging = true;
        Console.WriteLine($"[P2P JoinSwarm] PeerId: {Convert.ToHexString(client.PeerId)}, Hash: {_computeHash}");
        var magnet = P2PCompute.BuildMagnetFromHash(_computeHash, _swarmName);
        Console.WriteLine($"[P2P JoinSwarm] Magnet: {magnet[..Math.Min(80, magnet.Length)]}...");
        _compute = await P2PCompute.JoinSwarmAsync(Crypto, client, accelerator, magnet);
        SwarmService.SetCompute(_compute);
        Console.WriteLine($"[P2P JoinSwarm] Joined. PeerCount: {_compute.PeerCount}, Bridge: {_compute.Bridge?.ComputePeerCount}");
        WireSwarmEvents();
        SaveSwarmState();
        LogActivity("\ud83d\udd17", "Joined swarm as worker", "#3b82f6");
        StateHasChanged();
    }

