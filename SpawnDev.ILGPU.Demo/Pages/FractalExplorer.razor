@page "/fractals"
@page "/mandelbrot"
@implements IAsyncDisposable
@using SpawnDev.ILGPU.WebGPU
@using SpawnDev.ILGPU.WebGPU.Backend

@using SpawnDev.ILGPU.WebGL
@using SpawnDev.ILGPU.WebGL.Backend
@using SpawnDev.ILGPU.Wasm
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@using ILGPU
@using System.Diagnostics
@using System.Runtime.InteropServices
@using SpawnDev.ILGPU.Demo.Shared.Kernels
@using global::ILGPU
@using global::ILGPU.Runtime
@using global::ILGPU.Runtime.CPU

<PageTitle>Fractal Explorer</PageTitle>

<h1>Fractal Explorer</h1>

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-header">Controls</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Backend Engine</label>
                    <select class="form-select" value="@_selectedBackend" @onchange="OnBackendChanged" disabled="@(_isInitializing)">                    
                        @foreach (var backend in _availableBackends)
                        {
                            <option value="@backend.Key">@backend.Value</option>
                        }
                    </select>
                    @if (_isInitializing)
                    {
                        <small class="text-muted mt-1 d-block">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            Initializing @_selectedBackend...
                        </small>
                    }
                    else if (!string.IsNullOrEmpty(_backendStatus))
                    {
                        <small class="text-success mt-1 d-block">✓ @_backendStatus</small>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Fractal Type</label>
                    <select class="form-select" @bind="_fractalType">
                        <option value="0">Mandelbrot</option>
                        <option value="1">Julia Set</option>
                        <option value="2">Burning Ship</option>
                        <option value="3">Tricorn</option>
                        <option value="4">Phoenix</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Max Iterations: <strong>@_maxIterations</strong></label>
                    <input type="range" class="form-range" min="50" max="2000" step="50" @bind="_maxIterations" @bind:event="oninput" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Color Scheme</label>
                    <select class="form-select" @bind="_colorScheme">
                        <option value="0">Classic</option>
                        <option value="1">Smooth</option>
                        <option value="2">Fire</option>
                        <option value="3">Ocean</option>
                        <option value="4">Neon</option>
                    </select>
                </div>

                @if (_fractalType == 1)
                {
                    <hr />
                    <div class="mb-3">
                        <label class="form-label">Julia Real: <strong>@_juliaReal.ToString("F4")</strong></label>
                        <input type="range" class="form-range" min="-2" max="2" step="0.01" @bind="_juliaReal" @bind:event="oninput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Julia Imag: <strong>@_juliaImag.ToString("F4")</strong></label>
                        <input type="range" class="form-range" min="-2" max="2" step="0.01" @bind="_juliaImag" @bind:event="oninput" />
                    </div>
                }

                @if (_fractalType == 4)
                {
                    <hr />
                    <div class="mb-3">
                        <label class="form-label">Phoenix P: <strong>@_phoenixP.ToString("F4")</strong></label>
                        <input type="range" class="form-range" min="-2" max="2" step="0.01" @bind="_phoenixP" @bind:event="oninput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phoenix Q: <strong>@_phoenixQ.ToString("F4")</strong></label>
                        <input type="range" class="form-range" min="-2" max="2" step="0.01" @bind="_phoenixQ" @bind:event="oninput" />
                    </div>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Performance</div>
            <div class="card-body">
                <canvas @ref="_fpsCanvas" width="220" height="80" style="width:100%; border:1px solid #444; border-radius:4px; background:#1a1a2e;"></canvas>
                <div class="mt-2">
                    <small>
                        <div><strong>Backend:</strong> @_selectedBackend</div>
                        <div><strong>FPS:</strong> @_currentFps.ToString("F1")</div>
                        <div><strong>Total:</strong> @_lastRenderMs.ToString("F1") ms</div>
                        <div><strong>Kernel:</strong> @_lastKernelMs.ToString("F1") ms</div>
                        <div><strong>Readback:</strong> @_lastReadbackMs.ToString("F1") ms</div>
                        <div><strong>Zoom:</strong> @FormatZoom()</div>
                        <div><strong>Center:</strong> @FormatCoord(_centerX), @FormatCoord(_centerY)</div>
                    </small>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Instructions</div>
            <div class="card-body">
                <ul class="mb-0 small">
                    <li><strong>Zoom:</strong> Mouse wheel</li>
                    <li><strong>Pan:</strong> Click & drag</li>
                    <li><strong>Reset:</strong> Double-click</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="text-center">
            <canvas @ref="_mainCanvas"
                    width="@_width"
                    height="@_height"
                    style="border: 1px solid #444; cursor: crosshair; border-radius: 4px; max-width: 100%;"
                    tabindex="0"
                    @onwheel="OnWheel"
                    @onwheel:preventDefault
                    @onmousedown="OnMouseDown"
                    @onmousemove="OnMouseMove"
                    @onmouseup="OnMouseUp"
                    @onmouseleave="OnMouseUp"
                    @ondblclick="OnDoubleClick"></canvas>
        </div>
    </div>
</div>

@code {
    [Inject]
    BlazorJSRuntime JS { get; set; } = default!;

    ElementReference _mainCanvas;
    ElementReference _fpsCanvas;

    // Canvas size
    private int _width = 900;
    private int _height = 700;

    // Backend selection
    private string _selectedBackend = "";
    private string _backendStatus = "";
    private bool _isInitializing = false;
    private bool _pendingBackendSwitch = false;
    private List<KeyValuePair<string, string>> _availableBackends = new();

    // Fractal parameters
    private int _fractalType = 0;
    private int _colorScheme = 0;
    private int _maxIterations = 500;
    private double _centerX = -0.5;
    private double _centerY = 0.0;
    private double _zoom = 1.0;

    // Julia set parameters
    private double _juliaReal = -0.7;
    private double _juliaImag = 0.27015;

    // Phoenix parameters
    private double _phoenixP = 0.5667;
    private double _phoenixQ = -0.5;

    // State
    private bool _isRunning = false;
    private bool _disposed = false;
    private double _lastRenderMs = 0;
    private double _lastKernelMs = 0;
    private double _lastReadbackMs = 0;
    private double _currentFps = 0;

    // FPS tracking
    private double[] _fpsHistory = new double[120];
    private int _fpsIndex = 0;
    private DateTime _lastFrameTime = DateTime.UtcNow;

    // UI throttling
    private DateTime _lastUiUpdate = DateTime.MinValue;
    private const int UI_UPDATE_INTERVAL_MS = 100;

    // Mouse drag
    private bool _isDragging = false;
    private double _lastMouseX;
    private double _lastMouseY;

    // Cached ILGPU resources
    private Context? _ilgpuContext;
    private Accelerator? _ilgpuAccelerator;
    private Action<Index2D, ArrayView2D<uint, Stride2D.DenseX>,
        int, int, int,
        double, double, double, double, double>? _kernel;
    private MemoryBuffer2D<uint, Stride2D.DenseX>? _outputBuffer;

    // Cached rendering resources (avoid per-frame allocations)
    private uint[]? _cachedResult;
    private CanvasRenderingContext2D? _cachedMainCtx;
    private CanvasRenderingContext2D? _cachedFpsCtx;
    private ImageData? _cachedImageData;
    private Uint8ClampedArray? _cachedDestPixels;
    private int _cachedResultWidth;
    private int _cachedResultHeight;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await DetectAvailableBackends();
            _ = RenderLoop();
        }
    }

    private async Task DetectAvailableBackends()
    {
        var backends = new List<KeyValuePair<string, string>>();

        // WebGPU — requires async GPU probing, may not be available
        try
        {
            using var probeContext = await Context.CreateAsync(builder => builder.WebGPU());
            var devices = probeContext.GetWebGPUDevices();
            if (devices.Count > 0)
            {
                backends.Add(new("WebGPU", "⚡⚡⚡ WebGPU (GPU)"));
            }
        }
        catch
        {
            // WebGPU not available in this browser
        }

        // WebGL2 — requires async probing, may not be available
        try
        {
            using var glProbeContext = await Context.CreateAsync(builder => builder.WebGL());
            var glDevices = glProbeContext.GetWebGLDevices();
            if (glDevices.Count > 0)
            {
                backends.Add(new("WebGL", "⚡⚡ WebGL2 (GPU Compute)"));
            }
        }
        catch
        {
            // WebGL2 not available in this browser
        }

        // Wasm — always available in Blazor WASM
        backends.Add(new("Wasm", "⚡ Wasm (Multi-core Wasm)"));



        // CPU — always available
        backends.Add(new("CPU", "🐢 CPU (Single-thread)"));

        _availableBackends = backends;
        _selectedBackend = backends[0].Key; // Best available
        StateHasChanged();
    }

    // ========== Backend Switching ==========

    private async Task OnBackendChanged(ChangeEventArgs e)
    {
        var newBackend = e.Value?.ToString() ?? "WebGPU";
        if (newBackend == _selectedBackend) return;

        _selectedBackend = newBackend;
        _pendingBackendSwitch = true;
        StateHasChanged();
    }

    private async Task SwitchBackend()
    {
        _isInitializing = true;
        _backendStatus = "";
        StateHasChanged();
        await Task.Yield();

        try
        {
            // Dispose old resources
            DisposeAcceleratorResources();

            // Create new accelerator for the selected backend
            await InitializeBackend(_selectedBackend);
            _backendStatus = $"{_ilgpuAccelerator!.Name}";

            // Reset FPS history for clean comparison
            _fpsHistory = new double[120];
            _fpsIndex = 0;
            _lastKernelMs = 0;
            _lastReadbackMs = 0;
            _lastRenderMs = 0;
            _currentFps = 0;
        }
        catch (Exception ex)
        {
            _backendStatus = $"Error: {ex.Message}";
            Console.WriteLine($"Backend switch error: {ex}");
        }
        finally
        {
            _isInitializing = false;
            _pendingBackendSwitch = false;
            StateHasChanged();
        }
    }

    private void DisposeAcceleratorResources()
    {
        _kernel = null;
        _outputBuffer?.Dispose();
        _outputBuffer = null;
        _ilgpuAccelerator?.Dispose();
        _ilgpuAccelerator = null;
        _ilgpuContext?.Dispose();
        _ilgpuContext = null;
    }

    private void DisposeRenderingCaches()
    {
        _cachedDestPixels?.Dispose();
        _cachedDestPixels = null;
        _cachedImageData?.Dispose();
        _cachedImageData = null;
        _cachedMainCtx?.Dispose();
        _cachedMainCtx = null;
        _cachedFpsCtx?.Dispose();
        _cachedFpsCtx = null;
        _cachedResult = null;
        _cachedResultWidth = 0;
        _cachedResultHeight = 0;
    }

    // ========== Initialization ==========

    private async Task InitializeBackend(string backendName)
    {
        switch (backendName)
        {
            case "WebGPU":
                await InitializeWebGPU();
                break;
            case "WebGL":
                await InitializeWebGL();
                break;

            case "Wasm":
                await InitializeWasm();
                break;
            case "CPU":
                await InitializeCPU();
                break;
            default:
                throw new ArgumentException($"Unknown backend: {backendName}");
        }

        // Load kernel and allocate buffer (same for all backends)
        _kernel = _ilgpuAccelerator!.LoadAutoGroupedStreamKernel<
            Index2D, ArrayView2D<uint, Stride2D.DenseX>,
            int, int, int,
            double, double, double, double, double>(FractalKernels.Render);
        _outputBuffer = _ilgpuAccelerator.Allocate2DDenseX<uint>(new Index2D(_width, _height));
    }

    private async Task InitializeWebGPU()
    {
        _ilgpuContext = await Context.CreateAsync(builder => builder.WebGPU());
        var devices = _ilgpuContext.GetWebGPUDevices();
        if (devices.Count == 0) throw new Exception("No WebGPU device found");
        _ilgpuAccelerator = await devices[0].CreateAcceleratorAsync(_ilgpuContext);
    }

    private async Task InitializeWebGL()
    {
        // Temporarily enable verbose logging to diagnose shader generation
        WebGLBackend.VerboseLogging = true;
        WebGLAccelerator.VerboseLogging = true;
        _ilgpuContext = await Context.CreateAsync(builder => builder.WebGL());
        var devices = _ilgpuContext.GetWebGLDevices();
        if (devices.Count == 0) throw new Exception("No WebGL2 device found");
        // Enable f64 emulation for full 64-bit float precision. I64 disabled to keep
        // integer ops (loop counters, color packing) as native int32 for correctness.
        var options = new WebGLBackendOptions { EnableF64Emulation = true, EnableI64Emulation = false };
        _ilgpuAccelerator = devices[0].CreateAccelerator(_ilgpuContext, options);
    }



    private async Task InitializeWasm()
    {
        _ilgpuContext = await Context.CreateAsync(builder => builder.Wasm());
        var devices = _ilgpuContext.GetDevices<WasmILGPUDevice>();
        if (devices.Count == 0) throw new Exception("No Wasm device found");
        _ilgpuAccelerator = await devices[0].CreateAcceleratorAsync(_ilgpuContext);
    }

    private Task InitializeCPU()
    {
        var device = new CPUDevice(
            numThreadsPerWarp: 4,
            numWarpsPerMultiprocessor: 16,
            numMultiprocessors: 1);
        _ilgpuContext = Context.Create().CPU(device).ToContext();
        _ilgpuAccelerator = _ilgpuContext.CreateCPUAccelerator(0);
        return Task.CompletedTask;
    }

    // ========== Render Loop ==========

    private async Task RenderLoop()
    {
        try
        {
            await InitializeBackend(_selectedBackend);
            _backendStatus = $"{_ilgpuAccelerator!.Name}";
            StateHasChanged();

            while (!_disposed)
            {
                if (_pendingBackendSwitch)
                {
                    await SwitchBackend();
                    continue;
                }

                if (_isRunning || _isInitializing)
                {
                    await Task.Delay(10);
                    continue;
                }

                await RenderFrame();
                ThrottledStateHasChanged();
                await Task.Yield();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Render loop error: {ex}");
            _backendStatus = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    private void ThrottledStateHasChanged()
    {
        var now = DateTime.UtcNow;
        if ((now - _lastUiUpdate).TotalMilliseconds >= UI_UPDATE_INTERVAL_MS)
        {
            _lastUiUpdate = now;
            StateHasChanged();
        }
    }

    private string FormatZoom() => _zoom.ToString("G6");
    private string FormatCoord(double val) => val.ToString("G10");

    // ========== Mouse Interaction ==========

    private void OnWheel(WheelEventArgs e)
    {
        double mouseX = e.OffsetX;
        double mouseY = e.OffsetY;

        double scale = 4.0 / _zoom;
        double mouseRealBefore = _centerX + (mouseX - _width / 2.0) * scale / _width;
        double mouseImagBefore = _centerY + (mouseY - _height / 2.0) * scale / _height;

        double zoomFactor = e.DeltaY < 0 ? 1.2 : 1.0 / 1.2;
        _zoom *= zoomFactor;
        _zoom = Math.Max(0.5, Math.Min(_zoom, 1e12));

        double newScale = 4.0 / _zoom;
        _centerX = mouseRealBefore - (mouseX - _width / 2.0) * newScale / _width;
        _centerY = mouseImagBefore - (mouseY - _height / 2.0) * newScale / _height;
    }

    private void OnMouseDown(MouseEventArgs e)
    {
        _isDragging = true;
        _lastMouseX = e.OffsetX;
        _lastMouseY = e.OffsetY;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (!_isDragging) return;

        double dx = e.OffsetX - _lastMouseX;
        double dy = e.OffsetY - _lastMouseY;
        if (Math.Abs(dx) < 0.5 && Math.Abs(dy) < 0.5) return;

        double scale = 4.0 / _zoom;
        _centerX -= dx * scale / _width;
        _centerY -= dy * scale / _height;

        _lastMouseX = e.OffsetX;
        _lastMouseY = e.OffsetY;
    }

    private void OnMouseUp(MouseEventArgs e)
    {
        _isDragging = false;
    }

    private void OnDoubleClick(MouseEventArgs e)
    {
        _zoom = 1.0;
        switch (_fractalType)
        {
            case 0: _centerX = -0.5; _centerY = 0.0; break;
            case 1: _centerX = 0.0; _centerY = 0.0; break;
            case 2: _centerX = -0.4; _centerY = -0.5; break;
            case 3: _centerX = -0.5; _centerY = 0.0; break;
            case 4: _centerX = 0.0; _centerY = 0.0; break;
        }
    }

    // ========== Rendering ==========

    private async Task RenderFrame()
    {
        if (_kernel == null || _outputBuffer == null || _ilgpuAccelerator == null) return;

        _isRunning = true;
        try
        {
            var sw = Stopwatch.StartNew();

            // Pack: fractalType*256 + colorScheme, width*65536 + height
            int packedSize = _width * 65536 + _height;
            int packedConfig = _fractalType * 256 + _colorScheme;
            double extra1 = _fractalType == 1 ? _juliaReal : _phoenixP;
            double extra2 = _fractalType == 1 ? _juliaImag : _phoenixQ;

            // Dispatch kernel
            _kernel(
                _outputBuffer.IntExtent, _outputBuffer.View,
                packedSize, _maxIterations, packedConfig,
                _centerX, _centerY, _zoom, extra1, extra2);

            // Sync (unified — works for all backends)
            await _ilgpuAccelerator.SynchronizeAsync();

            var kernelTime = sw.Elapsed.TotalMilliseconds;
            _lastKernelMs = kernelTime;

            // Canvas blit — uses ctx.CreateImageData for non-shared buffer backing.
            // In multi-threaded Blazor WASM, the .NET heap is a SharedArrayBuffer,
            // so ImageData(Uint8ClampedArray) rejects all views from .NET or shared memory.
            // Solution: CreateImageData creates non-shared backing, then .Data.Set() copies into it.
            var swReadback = Stopwatch.StartNew();
            var internalBuffer = ((IArrayView)_outputBuffer).Buffer;
            int pixelCount = _width * _height;
            int byteCount = pixelCount * 4;

            // Cache the canvas 2D context — it never changes between frames
            if (_cachedMainCtx == null)
            {
                using var canvas = new HTMLCanvasElement(_mainCanvas);
                _cachedMainCtx = canvas.GetContext<CanvasRenderingContext2D>("2d");
            }

            // Cache the ImageData and its Data pixel buffer (non-shared) — rebuild only on dimension change
            if (_cachedImageData == null || _cachedResultWidth != _width || _cachedResultHeight != _height)
            {
                _cachedDestPixels?.Dispose();
                _cachedImageData?.Dispose();
                _cachedImageData = _cachedMainCtx!.CreateImageData(_width, _height);
                _cachedDestPixels = _cachedImageData.Data;
                _cachedResultWidth = _width;
                _cachedResultHeight = _height;
                // Also resize the cached result array
                _cachedResult = new uint[pixelCount];
            }

            var destPixels = _cachedDestPixels!;
            if (internalBuffer is IBrowserMemoryBuffer browserMemoryBuffer)
            {
                // JS-side copy: source view from shared buffer → non-shared ImageData
                using var srcView = await browserMemoryBuffer.CopyToHostUint8ArrayAsync(0, byteCount);
                destPixels.Set(srcView);
            }

            else if (internalBuffer is WasmMemoryBuffer wasmBuf)
            {
                // JS-side copy: source view from shared buffer → non-shared ImageData
                using var srcView = await wasmBuf.CopyToHostUint8ArrayAsync(0, byteCount);
                //using var srcView = new Uint8Array(wasmBuf.SharedBuffer, 0, byteCount);
                destPixels.Set(srcView);
            }
            else if (internalBuffer is WebGLMemoryBuffer webGlBuf)
            {
                // JS-side copy: source view from regular ArrayBuffer → non-shared ImageData
                using var srcView = await webGlBuf.CopyToHostUint8ArrayAsync(0, byteCount);
                destPixels.Set(srcView);
            }
            else if (internalBuffer is WebGPUMemoryBuffer webGpuBuf)
            {
                // WebGPU: cached staging readback → Write to ImageData (zero-alloc hot path)
                using var srcView = await webGpuBuf.CopyToHostUint8ArrayAsync(0, byteCount);
                destPixels.Set(srcView);
            }
            else
            {
                // CPU fallback: read to .NET, Write to ImageData
                _outputBuffer.View.BaseView.CopyToCPU(_cachedResult!);
                destPixels.Write(_cachedResult!);
            }

            _cachedMainCtx!.PutImageData(_cachedImageData, 0, 0);

            swReadback.Stop();
            _lastReadbackMs = swReadback.Elapsed.TotalMilliseconds;

            sw.Stop();
            _lastRenderMs = sw.Elapsed.TotalMilliseconds;

            // Update FPS
            var now = DateTime.UtcNow;
            var dt = (now - _lastFrameTime).TotalSeconds;
            _lastFrameTime = now;
            if (dt > 0)
            {
                _fpsHistory[_fpsIndex % _fpsHistory.Length] = 1.0 / dt;
                _fpsIndex++;
                _currentFps = 1.0 / dt;
            }

            await DrawFpsGraph();
        }
        finally
        {
            _isRunning = false;
        }
    }

    private async Task DrawFpsGraph()
    {
        try
        {
            // Cache the FPS canvas 2D context
            if (_cachedFpsCtx == null)
            {
                using var canvas = new HTMLCanvasElement(_fpsCanvas);
                _cachedFpsCtx = canvas.GetContext<CanvasRenderingContext2D>("2d");
                if (_cachedFpsCtx == null) return;
            }
            var ctx = _cachedFpsCtx;

            int w = 220, h = 80;
            ctx.ClearRect(0, 0, w, h);

            double maxFps = 10;
            int count = Math.Min(_fpsIndex, _fpsHistory.Length);
            for (int i = 0; i < count; i++)
                maxFps = Math.Max(maxFps, _fpsHistory[i]);

            double barWidth = (double)w / _fpsHistory.Length;
            for (int i = 0; i < count; i++)
            {
                int idx = (_fpsIndex - count + i + _fpsHistory.Length) % _fpsHistory.Length;
                double fps = _fpsHistory[idx];
                double barHeight = (fps / maxFps) * (h - 15);

                double ratio = fps / maxFps;
                int r = (int)(255 * (1 - ratio));
                int g = (int)(255 * ratio);
                ctx.FillStyle = $"rgb({r},{g},80)";
                ctx.FillRect(i * barWidth, h - barHeight - 10, Math.Max(barWidth - 1, 1), barHeight);
            }

            ctx.FillStyle = "#e0e0e0";
            ctx.Font = "11px monospace";
            ctx.FillText($"{_currentFps:F0} FPS  |  {maxFps:F0} max", 5, 10);
        }
        catch { }
    }

    // ========== Disposal ==========

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        await Task.Delay(100);
        DisposeRenderingCaches();
        DisposeAcceleratorResources();
    }
}
