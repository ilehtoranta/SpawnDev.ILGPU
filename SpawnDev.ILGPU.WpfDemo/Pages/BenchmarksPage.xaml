<UserControl x:Class="SpawnDev.ILGPU.WpfDemo.Pages.BenchmarksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <!-- Run button style -->
        <Style x:Key="RunBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Padding="20,10"
                                Background="{StaticResource AccentGradientBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="20" ShadowDepth="2" Opacity="0.4" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card border style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgDeepBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="960" Margin="40,24,40,40" HorizontalAlignment="Center">

                <!-- Header -->
                <TextBlock FontSize="28" FontWeight="Bold" Margin="0,0,0,4"
                           HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#3B82F6" Offset="0" />
                            <GradientStop Color="#A855F7" Offset="0.5" />
                            <GradientStop Color="#EC4899" Offset="1" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    ⚡ Backend Benchmarks
                </TextBlock>
                <TextBlock Text="Compare CUDA, OpenCL, and CPU performance"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Center" Margin="0,0,0,20" />

                <!-- Controls row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Button x:Name="RunButton" Content="▶  Run All Benchmarks"
                            Style="{StaticResource RunBtnStyle}" Click="OnRunAll" />
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0" />
                </StackPanel>

                <!-- Progress -->
                <Border x:Name="ProgressPanel" Visibility="Collapsed"
                        Background="{StaticResource BgCardBrush}" CornerRadius="8"
                        Padding="16,12" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Height="6">
                            <Border Background="#1E293B" CornerRadius="3" />
                            <Border x:Name="ProgressFill" CornerRadius="3" HorizontalAlignment="Left" Width="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3B82F6" Offset="0" />
                                        <GradientStop Color="#A855F7" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="ProgressLabel" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Overall Ranking (at top as requested) -->
                <Border x:Name="RankingCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🏆 Overall Ranking" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />
                        <ItemsControl x:Name="RankingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0AFFFFFF" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding RankLabel}" FontWeight="Bold" FontSize="14"
                                                       Foreground="#A855F7" VerticalAlignment="Center" />
                                            <Ellipse Grid.Column="1" Width="10" Height="10" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding DotColor}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontWeight="SemiBold"
                                                       FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <TextBlock Grid.Column="3" Text="{Binding WinsLabel}" FontSize="13"
                                                       Foreground="#FACC15" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="0,0,16,0" />
                                            <TextBlock Grid.Column="4" Text="{Binding AvgLabel}" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Results container -->
                <StackPanel x:Name="ResultsPanel" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
