<UserControl x:Class="SpawnDev.ILGPU.WpfDemo.Pages.BoidsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Background="{StaticResource BgMainBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <!-- Backend -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Backend" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <ComboBox x:Name="BackendCombo" FontSize="12.5"
                                  SelectionChanged="OnBackendChanged" />
                        <TextBlock x:Name="BackendStatus" Text="Detecting..." FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Boids Controls -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Particles" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <ComboBox x:Name="ParticleCountCombo" SelectedIndex="2" FontSize="12.5"
                                  SelectionChanged="OnParticleCountChanged">
                            <ComboBoxItem Content="500" Tag="500" />
                            <ComboBoxItem Content="1,000" Tag="1000" />
                            <ComboBoxItem Content="2,000" Tag="2000" />
                            <ComboBoxItem Content="5,000" Tag="5000" />
                            <ComboBoxItem Content="10,000" Tag="10000" />
                            <ComboBoxItem Content="20,000" Tag="20000" />
                        </ComboBox>

                        <TextBlock Text="Species" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,12,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="SpeciesSlider" Minimum="1" Maximum="5" Value="3"
                                    IsSnapToTickEnabled="True" TickFrequency="1" Width="180"
                                    ValueChanged="OnSpeciesChanged" />
                            <TextBlock x:Name="SpeciesLabel" Text="3" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <Separator Background="{StaticResource BorderSubtleBrush}" Margin="0,8" />

                        <TextBlock Text="Separation" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="SeparationSlider" Minimum="0" Maximum="3" Value="1.5" Width="180"
                                    ValueChanged="OnParamChanged" />
                            <TextBlock x:Name="SeparationLabel" Text="1.50" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Alignment" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,4,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="AlignmentSlider" Minimum="0" Maximum="3" Value="1.0" Width="180"
                                    ValueChanged="OnParamChanged" />
                            <TextBlock x:Name="AlignmentLabel" Text="1.00" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Cohesion" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,4,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="CohesionSlider" Minimum="0" Maximum="3" Value="1.0" Width="180"
                                    ValueChanged="OnParamChanged" />
                            <TextBlock x:Name="CohesionLabel" Text="1.00" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Speed" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,4,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="SpeedSlider" Minimum="0.5" Maximum="5" Value="2.0" Width="180"
                                    ValueChanged="OnParamChanged" />
                            <TextBlock x:Name="SpeedLabel" Text="2.0" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Performance -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Performance" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <Image x:Name="FpsGraphImage" Width="200" Height="50" Margin="0,0,0,8" />
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                <Run Text="Backend: " /><Run x:Name="PerfBackend" Text="-" />
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                <Run Text="FPS: " /><Run x:Name="PerfFps" Text="0" />
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                <Run Text="Sim: " /><Run x:Name="PerfSim" Text="0" /><Run Text=" ms" />
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                <Run Text="Render: " /><Run x:Name="PerfKernel" Text="0" /><Run Text=" ms" />
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                <Run Text="Particles: " /><Run x:Name="PerfParticles" Text="2000" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Instructions -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Instructions" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="• Orbit: Click &amp; drag" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Text="• Zoom: Mouse wheel" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Text="• Reset: Double-click" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Canvas -->
        <Border Grid.Column="1" Background="{StaticResource BgDeepBrush}" Margin="8"
                CornerRadius="8" ClipToBounds="True">
            <Image x:Name="SceneImage" Stretch="Uniform"
                   MouseWheel="OnMouseWheel"
                   MouseDown="OnMouseDown"
                   MouseMove="OnMouseMove"
                   MouseUp="OnMouseUp" />
        </Border>
    </Grid>
</UserControl>
