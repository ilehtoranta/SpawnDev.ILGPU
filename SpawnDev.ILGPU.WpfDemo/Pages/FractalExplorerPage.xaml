<UserControl x:Class="SpawnDev.ILGPU.WpfDemo.Pages.FractalExplorerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeepBrush}"
             Loaded="OnLoaded">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Controls Panel -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="Fractal Explorer" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                <!-- Backend Engine -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Backend Engine" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <ComboBox x:Name="BackendCombo" SelectionChanged="OnBackendChanged"
                                  Background="#1E293B" Foreground="White" FontSize="12.5" />
                        <TextBlock x:Name="BackendStatus" FontSize="11" Margin="0,6,0,0"
                                   Foreground="{StaticResource SuccessGreenBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Fractal Type -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Fractal Type" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <ComboBox x:Name="FractalTypeCombo" SelectedIndex="0" FontSize="12.5"
                                  SelectionChanged="OnFractalTypeChanged"
                                  Background="#1E293B" Foreground="White">
                            <ComboBoxItem Content="Mandelbrot" />
                            <ComboBoxItem Content="Julia Set" />
                            <ComboBoxItem Content="Burning Ship" />
                            <ComboBoxItem Content="Tricorn" />
                            <ComboBoxItem Content="Phoenix" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Max Iterations -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6">
                            <Run Text="Max Iterations: " FontWeight="SemiBold" />
                            <Run x:Name="IterationsLabel" Text="500" FontWeight="Bold" />
                        </TextBlock>
                        <Slider x:Name="IterationsSlider" Minimum="50" Maximum="2000" Value="500"
                                TickFrequency="50" IsSnapToTickEnabled="True"
                                ValueChanged="OnIterationsChanged" />
                    </StackPanel>
                </Border>

                <!-- Color Scheme -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Color Scheme" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <ComboBox x:Name="ColorSchemeCombo" SelectedIndex="0" FontSize="12.5"
                                  SelectionChanged="OnColorSchemeChanged"
                                  Background="#1E293B" Foreground="White">
                            <ComboBoxItem Content="Classic" />
                            <ComboBoxItem Content="Smooth" />
                            <ComboBoxItem Content="Fire" />
                            <ComboBoxItem Content="Ocean" />
                            <ComboBoxItem Content="Neon" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Julia Parameters (conditional) -->
                <Border x:Name="JuliaPanel" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6">
                            <Run Text="Julia Real: " FontWeight="SemiBold" />
                            <Run x:Name="JuliaRealLabel" Text="-0.7000" />
                        </TextBlock>
                        <Slider x:Name="JuliaRealSlider" Minimum="-2" Maximum="2" Value="-0.7"
                                TickFrequency="0.01" IsSnapToTickEnabled="True"
                                ValueChanged="OnJuliaParamChanged" />
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,6">
                            <Run Text="Julia Imag: " FontWeight="SemiBold" />
                            <Run x:Name="JuliaImagLabel" Text="0.2702" />
                        </TextBlock>
                        <Slider x:Name="JuliaImagSlider" Minimum="-2" Maximum="2" Value="0.27015"
                                TickFrequency="0.01" IsSnapToTickEnabled="True"
                                ValueChanged="OnJuliaParamChanged" />
                    </StackPanel>
                </Border>

                <!-- Phoenix Parameters (conditional) -->
                <Border x:Name="PhoenixPanel" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6">
                            <Run Text="Phoenix P: " FontWeight="SemiBold" />
                            <Run x:Name="PhoenixPLabel" Text="0.5667" />
                        </TextBlock>
                        <Slider x:Name="PhoenixPSlider" Minimum="-2" Maximum="2" Value="0.5667"
                                TickFrequency="0.01" IsSnapToTickEnabled="True"
                                ValueChanged="OnPhoenixParamChanged" />
                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,6">
                            <Run Text="Phoenix Q: " FontWeight="SemiBold" />
                            <Run x:Name="PhoenixQLabel" Text="-0.5000" />
                        </TextBlock>
                        <Slider x:Name="PhoenixQSlider" Minimum="-2" Maximum="2" Value="-0.5"
                                TickFrequency="0.01" IsSnapToTickEnabled="True"
                                ValueChanged="OnPhoenixParamChanged" />
                    </StackPanel>
                </Border>

                <!-- Performance -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Performance" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        
                        <!-- FPS Graph -->
                        <Border Background="#0F172A" CornerRadius="4" Padding="0" Margin="0,0,0,8"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <Image x:Name="FpsGraphImage" Height="60" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                        </Border>

                        <TextBlock FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18">
                            <Run Text="Backend: " FontWeight="SemiBold" /><Run x:Name="PerfBackend" Text="—" /><LineBreak/>
                            <Run Text="FPS: " FontWeight="SemiBold" /><Run x:Name="PerfFps" Text="—" /><LineBreak/>
                            <Run Text="Total: " FontWeight="SemiBold" /><Run x:Name="PerfTotal" Text="—" /> ms<LineBreak/>
                            <Run Text="Kernel: " FontWeight="SemiBold" /><Run x:Name="PerfKernel" Text="—" /> ms<LineBreak/>
                            <Run Text="Readback: " FontWeight="SemiBold" /><Run x:Name="PerfReadback" Text="—" /> ms<LineBreak/>
                            <Run Text="Zoom: " FontWeight="SemiBold" /><Run x:Name="PerfZoom" Text="1" /><LineBreak/>
                            <Run Text="Center: " FontWeight="SemiBold" /><Run x:Name="PerfCenter" Text="-0.5, 0" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Instructions -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Instructions" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20">
                            <Run FontWeight="SemiBold">Zoom:</Run> Mouse wheel<LineBreak/>
                            <Run FontWeight="SemiBold">Pan:</Run> Click &amp; drag<LineBreak/>
                            <Run FontWeight="SemiBold">Reset:</Run> Double-click
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Canvas Area -->
        <Border Grid.Column="1" Background="#111827" CornerRadius="8"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                ClipToBounds="True">
            <Image x:Name="FractalImage" Stretch="Uniform" Cursor="Cross"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   MouseWheel="OnMouseWheel"
                   MouseDown="OnMouseDown"
                   MouseMove="OnMouseMove"
                   MouseUp="OnMouseUp"
                   MouseLeftButtonDown="OnMouseDoubleClick" />
        </Border>
    </Grid>
</UserControl>
